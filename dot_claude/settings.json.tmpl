{ {{- /* https://code.claude.com/docs/en/settings */}}
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "autoMode": {
    "environment": [
      "$defaults"
    ],
    "allow": [
      "$defaults"
    ],
    "soft_deny": [
      "$defaults"
    ],
    "hard_deny": [
      "$defaults"
    ]
  },
  "autoScrollEnabled": true,
  "autoUpdatesChannel": "stable",
  "awaySummaryEnabled": true,
  "defaultShell": "bash",
  {{- /* "disableAutoMode": "disable", */}}
  "editorMode": "vim",
  "effortLevel": "high",
  "env": {
    {{- if .isMyMachine }}
    {{/*
    "ANTHROPIC_API_KEY": "",
    "ANTHROPIC_AUTH_TOKEN": "ollama",
    "ANTHROPIC_BASE_URL": "http://localhost:11434",
    */ -}}
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0", {{- /* TODO(dfrank): Enable telemetry */}}
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "0",
    "ENABLE_TOOL_SEARCH": "true",
    "OTEL_METRICS_EXPORTER": "otlp"
    {{- else if .isRiotMachine }} {{- /* https://docs.google.com/document/d/11tiv6iym5UBF3_fwMlFDqfWceDwVwaX3Gaejo5v9tus/edit?tab=t.0 */}}
    "ANTHROPIC_API_KEY": "",
    "ANTHROPIC_AUTH_TOKEN": {{ onepasswordRead "op://Riot/TrueFoundry - Personal Access Token/credential" | quote -}},
    "ANTHROPIC_BASE_URL": "https://truefoundry.riotgames.io/api/llm",
    {{- /* NOTE: Also see @dot_config/xonsh/exact_rc.d/60-aliases.xsh for model renames! */}}
    "ANTHROPIC_DEFAULT_OPUSPLAN_MODEL": "claude-vertex/anthropic-claude-opus-4-8",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-vertex/anthropic-claude-opus-4-8",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-vertex/anthropic-claude-sonnet-4-6-default[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-vertex/anthropic-claude-haiku-4-5-20251001",
    "DATADOG_API_KEY": {{ onepasswordRead "op://Riot/Datadog Access Keys - AI/API Key/api key" | quote }},
    "DATADOG_APP_KEY": {{ onepasswordRead "op://Riot/Datadog Access Keys - AI/Application Key/app key" | quote }},
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1",
    {{- /*
      ENABLE_TOOL_SEARCH defers MCP tool schemas out of context (lazy-loading), reclaiming
      ~33-45k tokens (~16-22% of a 200k window) that our 5 MCP servers otherwise consume up
      front. It requires the `advanced-tool-use-2025-11-20` anthropic-beta header.

      CURRENTLY A NO-OP on this Riot/Vertex stack: TrueFoundry forwards the beta correctly,
      but the upstream Vertex Anthropic deployment REJECTS *all* anthropic-beta values with
      `400 Unexpected value(s) ... for the anthropic-beta header` (verified 2026-06-04 across
      advanced-tool-use, prompt-caching-scope, redact-thinking, etc.). This is precisely why
      CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1 below is load-bearing — without it every
      request 400s. The two settings coexist intentionally: the disable flag keeps the
      session alive; this flag is a forward-looking no-op that will start working the moment
      Vertex accepts the beta, with no config change needed.

      Kept (not removed) so it activates automatically once supported. Re-test by toggling
      CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=0 in a throwaway session: if requests stop
      400ing, Vertex now accepts betas and Tool Search is live.
        Docs:  https://code.claude.com/docs/en/mcp (tool search auto-disables on Vertex / custom base URLs)
        Related (closed, client-side): https://github.com/anthropics/claude-code/issues/22893
      TODO(dfrank): drop CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS once Vertex accepts anthropic-beta values.
    */}}
    "ENABLE_TOOL_SEARCH": "true",
    "NODE_EXTRA_CA_CERTS": "{{ .chezmoi.homeDir }}/.local/share/mise/plugins/riot/certs/riot-issuing-ca.pem"
    {{- end }}
  },
  "hooks": {
    "SessionStart": [],
    "Setup": [],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/update-pane-title.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptExpansion": [],
    "PreToolUse": [],
    "PermissionRequest": [],
    "PermissionDenied": [],
    "PostToolUse": [],
    "PostToolUseFailure": [],
    "PostToolBatch": [],
    "Notification": [],
    "SubagentStart": [],
    "SubagentStop": [],
    "TaskCreated": [],
    "TaskCompleted": [],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/notify-stop.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "rm -f \"$HOME/.claude/task-labels/${TMUX_PANE}\"",
            "timeout": 5
          }
        ]
      }
    ],
    "StopFailure": [],
    "TeammateIdle": [],
    "InstructionsLoaded": [],
    "ConfigChange": [],
    "CwdChanged": [],
    "FileChanged": [],
    "WorktreeCreate": [],
    "WorktreeRemove": [],
    "PreCompact": [],
    "PostCompact": [],
    "Elicitation": [],
    "ElicitationResult": [],
    "SessionEnd": []
  },
  "includeGitInstruction": false,
  "language": "english",
  "model": "opusplan",
  "modelOverrides": {},
  "outputStyle": "Explanatory",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(brew *)",
      "Bash(chezmoi *)",
      "Bash(git *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git push --force-with-lease *)",
      "Bash(grep *)",
      "Bash(kill *)",
      "Bash(mise *)",
      "Bash(nvim *)",
      "Bash(pgrep *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(pkill *)",
      "Bash(rg *)",
      "Bash(tmux *)",
      "Bash(xargs *)",
      "Bash(xonsh *)"
    ],
    "ask": [
      "Bash(brew install *)"
    ],
    "deny": [
      "Bash(chezmoi destroy *)",
      "Bash(chezmoi purge *)",
      "Bash(git push --force *)"
    ]
  },
  "preferredNotificationChannel": "terminal_bell",
  "respectGitIgnore": true,
  "showTurnDuration": true,
  "skillOverrides": {},
  "skipDangerousModePermissionPrompt": true,
  "spinnerTipsEnabled": true,
  "spinnerTipsOverrides": {},
  "statusLine": {
    "command": "python3 ~/.claude/statusline.py",
    "type": "command"
  },
  "syntaxHighlightingDisabled": false,
  "theme": "dark-daltonized",
  "useAutoModeDuringPlan": false,
  "viewMode": "default"
}
