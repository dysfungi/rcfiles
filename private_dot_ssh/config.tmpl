Host github.com
    StrictHostKeyChecking accept-new
{{- if .isUnixLike }}
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
{{- end }}

{{- if .isRiotMachine }}
Host gh.riotgames.com
    StrictHostKeyChecking accept-new
{{- if .isUnixLike }}
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
{{- end }}
{{- end }}

Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
