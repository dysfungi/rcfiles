{{- /* codex model + provider base_url derive from .chezmoidata/large-language-models.yaml
       (the entry with `codex` in default_for). Declared at top level so both the
       model block and [model_providers.truefoundry] below can read them. */ -}}
{{- $codexModel := "" -}}
{{- $codexBaseUrl := "" -}}
{{- if .is_riot_machine -}}
  {{- includeTemplate "llm/validate.tmpl" .riot.llm -}}
  {{- range $m := .riot.llm.models -}}
    {{- if and (hasKey $m "default_for") (has "codex" $m.default_for) -}}
      {{- $codexModel = $m.id -}}
      {{- $codexBaseUrl = $m.gateway.base_url -}}
    {{- end -}}
  {{- end -}}
  {{- if eq $codexModel "" }}{{ fail "codex config: no catalog model has default_for codex" }}{{ end -}}
{{- end -}}
{{ if .is_my_machine -}}

model_reasoning_effort = "high"
personality = "pragmatic"
cli_auth_credentials_store = "file"  # ~/.codex/auth.json
mcp_oauth_credentials_store = "file" # ~/.codex/.credentials.json

{{ else if .is_riot_machine -}}

# https://www.notion.so/riotgames/Codex-CLI-2a77f9530fb28064ad81e4d1e6b19ea9?v=1eb7f9530fb2808cb97e000cd41c76b4&source=copy_link#2a77f9530fb28088967dcee527e752f6

model_provider = "truefoundry" # must be first line in doc
model = {{ $codexModel | quote }}
model_reasoning_effort = "xhigh"
personality = "pragmatic"
notify = [
  "{{ .chezmoi.homeDir }}/.codex/plugins/cache/openai-bundled/computer-use/1.0.755/Codex Computer Use.app/Contents/SharedSupport/SkyComputerUseClient.app/Contents/MacOS/SkyComputerUseClient",
  "turn-ended",
]
cli_auth_credentials_store = "file" # ~/.codex/auth.json
mcp_oauth_credentials_store = "file" # ~/.codex/.credentials.json

{{ end -}}

[marketplaces.openai-bundled]
last_updated = "2026-04-23T19:25:37Z"
source_type = "local"
source = "{{ .chezmoi.homeDir }}/.codex/.tmp/bundled-marketplaces/openai-bundled"

[marketplaces.openai-primary-runtime]
last_updated = "2026-04-23T19:25:37Z"
source_type = "local"
source = "{{ .chezmoi.homeDir }}/.cache/codex-runtimes/codex-primary-runtime/plugins/openai-primary-runtime"

{{- $mcpServersIn := .my.mcp_servers -}}
{{- if .is_riot_machine -}}
  {{- $mcpServersIn = mergeOverwrite $mcpServersIn .riot.mcp_servers -}}
{{- end -}}
{{- range $mcpName, $mcp := $mcpServersIn }}
{{- if hasKey $mcp "server_url" }}

[mcp_servers.{{ $mcpName }}] {{ $mcp.doc_url  | comment "# " }}
url = {{ $mcp.server_url | quote }}
{{- if hasKey $mcp "auth" -}}
  {{- if eq $mcp.auth.type "bearer" }}
headers = { Authorization = {{ printf "Bearer %s" (onepasswordRead $mcp.auth.op_path) | quote }} }
  {{- end -}}
{{- end }}

{{- end }}
{{- end }}

{{ if .is_riot_machine -}}

[model_providers.truefoundry]
name = "TrueFoundry"
base_url = {{ $codexBaseUrl | quote }}
env_key = "OPENAI_API_KEY"
wire_api = "responses"
supports_websockets = false

{{ end -}}

[plugins."browser-use@openai-bundled"]
enabled = true

[plugins."computer-use@openai-bundled"]
enabled = true

[plugins."documents@openai-primary-runtime"]
enabled = true

[plugins."presentations@openai-primary-runtime"]
enabled = true

[plugins."spreadsheets@openai-primary-runtime"]
enabled = true

{{- $projectsIn := .my.projects -}}
{{- if .is_riot_machine -}}
  {{- $projectsIn = concat $projectsIn .riot.projects -}}
{{- end -}}
{{- range $index, $project := $projectsIn -}}
{{- $only_on := dig "only_on" (list) $project -}}
{{- if or (empty $only_on) (and (has "wsl" $only_on) $.is_wsl) (and (has "linux" $only_on) $.is_linux) (and (has "darwin" $only_on) $.is_darwin) (and (has "windows" $only_on) $.is_windows) }}

{{ $projectKey := (dig "is_home_relative" false $project | ternary (joinPath $.chezmoi.homeDir $project.path) $project.path) -}}
[projects.{{ $projectKey | quote }}]
trust_level = "trusted"
{{- end }}
{{- end }}

[tui]
status_line = [
  "model-with-reasoning",
  "current-dir",
  "git-branch",
  "run-state",
  "context-used",
  "context-remaining",
  "context-window-size",
  "used-tokens",
  "total-input-tokens",
  "total-output-tokens",
  "five-hour-limit",
  "weekly-limit",
  "session-id",
  "thread-title",
  "task-progress",
  "fast-mode",
]

[windows]
sandbox = "elevated"
