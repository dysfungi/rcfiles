{ {{- /* https://code.claude.com/docs/en/settings */}}
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  {{- /* Empty attribution strings suppress Claude's default commit and PR markers. */}}
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "autoMode": {
    "environment": [
      "$defaults"
    ],
    "allow": [
      "$defaults"
    ],
    "soft_deny": [
      "$defaults"
    ],
    "hard_deny": [
      "$defaults"
    ]
  },
  "autoScrollEnabled": true,
  "autoUpdatesChannel": "stable",
  "awaySummaryEnabled": true,
  "defaultShell": "bash",
  {{- /* "disableAutoMode": "disable", */}}
  "editorMode": "vim",
  "effortLevel": "high",
  "env": {
    {{- if .is_my_machine }}
    {{/*
    "ANTHROPIC_API_KEY": "",
    "ANTHROPIC_AUTH_TOKEN": "ollama",
    "ANTHROPIC_BASE_URL": "http://localhost:11434",
    */ -}}
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0", {{- /* TODO(dfrank): Enable telemetry */}}
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "0",
    "ENABLE_TOOL_SEARCH": "true",
    "MISE_ENV": "agent", {{- /* mise agent profile: GH_TOKEN = machine-user PAT */}}
    "OTEL_METRICS_EXPORTER": "otlp"
    {{- else if .is_riot_machine }} {{- /* https://docs.google.com/document/d/11tiv6iym5UBF3_fwMlFDqfWceDwVwaX3Gaejo5v9tus/edit?tab=t.0 */}}
    {{- /* Base URL, auth token, and the OPUS/SONNET/HAIKU model ids derive from
           .chezmoidata/large-language-models.yaml: the anthropic gateway + the
           entries carrying alias: opus|sonnet|haiku (haiku is dormant in pi but
           still supplies claude's alias). */}}
    {{- includeTemplate "llm/validate.tmpl" .riot.llm -}}
    {{- $alias := dict -}}
    {{- $anthropicGw := dict -}}
    {{- range $m := .riot.llm.models -}}
      {{- if hasKey $m "alias" -}}{{- $_ := set $alias $m.alias $m.id -}}{{- end -}}
      {{- if and (eq $m.vendor "anthropic") (hasKey $m "gateway") -}}{{- $anthropicGw = $m.gateway -}}{{- end -}}
    {{- end -}}
    {{- if not (hasKey $anthropicGw "base_url") }}{{ fail "claude settings: no anthropic gateway in catalog" }}{{ end -}}
    {{- range $a := (list "opus" "sonnet" "haiku") -}}{{- if not (hasKey $alias $a) -}}{{- fail (printf "claude settings: no catalog model has alias %q" $a) -}}{{- end -}}{{- end }}
    "ANTHROPIC_API_KEY": "",
    "ANTHROPIC_AUTH_TOKEN": {{ onepasswordRead $anthropicGw.api_key_op | quote -}},
    "ANTHROPIC_BASE_URL": {{ $anthropicGw.base_url | quote }},
    {{- /* NOTE: Also see @dot_config/xonsh/exact_rc.d/60-aliases.xsh for model renames! */}}
    {{- /* "ANTHROPIC_DEFAULT_OPUSPLAN_MODEL": derive from alias opus if reintroduced */}}
    "ANTHROPIC_DEFAULT_OPUS_MODEL": {{ $alias.opus | quote }},
    "ANTHROPIC_DEFAULT_SONNET_MODEL": {{ $alias.sonnet | quote }},
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": {{ $alias.haiku | quote }},
    "DATADOG_API_KEY": {{ onepasswordRead "op://Riot/Datadog Access Keys - AI/API Key/api key" | quote }},
    "DATADOG_APP_KEY": {{ onepasswordRead "op://Riot/Datadog Access Keys - AI/Application Key/app key" | quote }},
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1",
    {{- /*
      ENABLE_TOOL_SEARCH defers MCP tool schemas out of context (lazy-loading), reclaiming
      ~33-45k tokens (~16-22% of a 200k window) that our 5 MCP servers otherwise consume up
      front. It requires the `advanced-tool-use-2025-11-20` anthropic-beta header.

      CURRENTLY A NO-OP on this Riot/Vertex stack: TrueFoundry forwards the beta correctly,
      but the upstream Vertex Anthropic deployment REJECTS *all* anthropic-beta values with
      `400 Unexpected value(s) ... for the anthropic-beta header` (verified 2026-06-04 across
      advanced-tool-use, prompt-caching-scope, redact-thinking, etc.). This is precisely why
      CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1 below is load-bearing — without it every
      request 400s. The two settings coexist intentionally: the disable flag keeps the
      session alive; this flag is a forward-looking no-op that will start working the moment
      Vertex accepts the beta, with no config change needed.

      Kept (not removed) so it activates automatically once supported. Re-test by toggling
      CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=0 in a throwaway session: if requests stop
      400ing, Vertex now accepts betas and Tool Search is live.
        Docs:  https://code.claude.com/docs/en/mcp (tool search auto-disables on Vertex / custom base URLs)
        Related (closed, client-side): https://github.com/anthropics/claude-code/issues/22893
      TODO(dfrank): drop CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS once Vertex accepts anthropic-beta values.
    */}}
    "ENABLE_TOOL_SEARCH": "true",
    "MISE_ENV": "agent", {{- /* mise agent profile: GH_TOKEN = machine-user PAT (github.com only; enterprise untouched) */}}
    "NODE_EXTRA_CA_CERTS": "{{ .chezmoi.homeDir }}/.local/share/mise/plugins/riot/certs/riot-issuing-ca.pem"
    {{- end }}
  },
  "hooks": {
    "SessionStart": [],
    "Setup": [],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/update-pane-title.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptExpansion": [],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/root_thread_guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "^ExitPlanMode$",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/exit_plan_review_gate.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [],
    "PermissionDenied": [],
    "PostToolUse": [],
    "PostToolUseFailure": [],
    "PostToolBatch": [],
    "Notification": [],
    "SubagentStart": [],
    "SubagentStop": [],
    "TaskCreated": [],
    "TaskCompleted": [],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/notify-stop.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "rm -f \"$HOME/.claude/task-labels/${TMUX_PANE}\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/clear_plan_review_sentinel.py",
            "timeout": 5
          }
        ]
      }
    ],
    "StopFailure": [],
    "TeammateIdle": [],
    "InstructionsLoaded": [],
    "ConfigChange": [],
    "CwdChanged": [],
    "FileChanged": [],
    "WorktreeCreate": [],
    "WorktreeRemove": [],
    "PreCompact": [],
    "PostCompact": [],
    "Elicitation": [],
    "ElicitationResult": [],
    "SessionEnd": []
  },
  "includeGitInstruction": false,
  "language": "english",
  "model": "opus",
  "modelOverrides": {},
  "outputStyle": "Explanatory",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(brew *)",
      "Bash(chezmoi *)",
      "Bash(git *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git rebase *)",
      "Bash(grep *)",
      "Bash(kill *)",
      "Bash(mise *)",
      "Bash(nvim *)",
      "Bash(pgrep *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(pkill *)",
      "Bash(rg *)",
      "Bash(tmux *)",
      "Bash(xargs *)",
      "Bash(xonsh *)"
    ],
    "ask": [
      "Bash(brew install *)"
    ],
    "deny": [
      "Bash(chezmoi destroy *)",
      "Bash(chezmoi purge *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push -f)",
      "Bash(git push --force)"
    ]
  },
  "preferredNotificationChannel": "terminal_bell",
  "respectGitIgnore": true,
  "showTurnDuration": true,
  "skillOverrides": {},
  "skipDangerousModePermissionPrompt": true,
  "spinnerTipsEnabled": true,
  "spinnerTipsOverrides": {},
  "statusLine": {
    "command": "python3 ~/.claude/statusline.py",
    "type": "command"
  },
  "syntaxHighlightingDisabled": false,
  "theme": "dark-daltonized",
  "useAutoModeDuringPlan": false,
  "viewMode": "default"
}
