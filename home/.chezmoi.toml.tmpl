{{ $username := .chezmoi.homeDir | base -}}
{{ if not (hasSuffix $username .chezmoi.username) -}}
  {{ fail (printf "username mismatch: homeDir base '%s' is not a suffix of chezmoi.username '%s'" $username .chezmoi.username) -}}
{{ end -}}

{{ $is_my_machine := eq $username "dmf" -}}
{{ $is_riot_machine := eq $username "dfrank" -}}
{{ $is_work_machine := not $is_my_machine -}}
{{ if or (eq $is_my_machine $is_work_machine $is_riot_machine) (ne $is_work_machine $is_riot_machine) -}}
  {{ fail "Failed to determine machine ownership" -}}
{{ end -}}

{{ $default_shell := "xonsh" -}}
{{ $wsl_distro := "archlinux" -}}

{{ $is_darwin := eq .chezmoi.os "darwin" -}}
{{ $is_linux := eq .chezmoi.os "linux" -}}
{{ $is_windows := eq .chezmoi.os "windows" -}}

{{- $paths_home    := list (joinPath .chezmoi.homeDir ".local/xonsh-env/xbin") (joinPath .chezmoi.homeDir ".local/bin") (joinPath .chezmoi.homeDir ".local/share/mise/shims") -}}
{{- $paths_darwin  := list "/opt/homebrew/bin" "/opt/homebrew/sbin" -}}
{{- $paths_system  := list "/usr/local/bin" "/usr/local/sbin" "/usr/bin" "/usr/sbin" "/bin" "/sbin" -}}
{{- $paths_platform := $is_darwin | ternary $paths_darwin (list) -}}
{{- $path_additions := concat $paths_home $paths_platform -}}
{{- $managed_paths  := concat $path_additions $paths_system | mustUniq -}}
{{- $paths_env := env "PATH" | splitList .chezmoi.pathListSeparator -}}
{{- /* NOTE: $paths_env included in $all_paths only on native Windows ($is_windows),
     where powershell/winget/wsl must be reachable from [scriptEnv] PATH.
     Excluded on WSL ($is_linux) to avoid /mnt/c/... interop path leakage. */}}
{{- $all_paths := without (concat $path_additions ($is_windows | ternary $paths_env (list)) $paths_system) "" | mustUniq -}}

{{ $op_token := env "OP_SERVICE_ACCOUNT_TOKEN" -}}
{{ if not $op_token -}}
  {{ fail "OP_SERVICE_ACCOUNT_TOKEN must be exported before running `chezmoi init` (see README bootstrap section)" -}}
{{ end -}}

{{ $my_github_token := onepasswordRead "op://CLI/GitHub Token - Chezmoi/password" }}
{{ $riot_github_token := "" }}
{{- if $is_riot_machine }}
{{ $riot_github_token = onepasswordRead "op://Riot/GitHub - Personal Access Token/password" }}
{{- end }}

[data]
name = "Derek M Frank"
github_username = "dysfungi"

email = {{ $is_riot_machine | ternary "dfrank@riotgames.com" "derek@frank.sh" | quote }}
is_my_machine = {{ $is_my_machine }}
is_work_machine = {{ $is_work_machine }}
is_riot_machine = {{ $is_riot_machine }}

default_shell = {{ $default_shell | quote }}
wsl_distro = {{ $wsl_distro | quote }}

username = {{ $username | quote }}

is_bsd = {{ eq .chezmoi.os "freebsd" "openbsd" }}
is_darwin = {{ $is_darwin }}
is_linux = {{ $is_linux }}
is_mac = {{ $is_darwin }}
is_unix_like = {{ eq .chezmoi.os "darwin" "freebsd" "linux" "openbsd" "unix" }}
is_windows = {{ $is_windows }}

{{ if $is_linux -}}
linux_distro = {{ .chezmoi.osRelease.id | quote }}
is_arch_linux = {{ eq .chezmoi.osRelease.id "arch" }}
is_wsl = {{ .chezmoi.kernel.osrelease | lower | contains "microsoft" }}
{{- else -}}
linux_distro = {{ .chezmoi.os | quote }}
is_arch_linux = false
is_wsl = false
{{- end }}

path_list = {{ $managed_paths | toToml }}
path_str = {{ $managed_paths | join .chezmoi.pathListSeparator | replace "\\" "/" | quote }}
path_home_list = {{ without $paths_home (joinPath .chezmoi.homeDir ".local/share/mise/shims") | toToml }}

github_token = {{ $my_github_token | quote }}
{{- if $is_riot_machine }}
riot_github_token = {{ $riot_github_token | quote }}
{{- end }}

op_service_account_token = {{ $op_token | quote }}

[cd]
args = [
    # "--rc=~/.config/xonsh/rc.xsh",
    # "--rc=~/.config/xonsh/rc.d/mise.xsh",
    # "-DXONSH_DEBUG=1",
    # "-DXONSH_SHOW_TRACEBACK=1",
    # "-DXONSH_TRACE_SUBPROC=2",
]

[diff]
exclude = ["scripts"]

# py interpreter overrides the default python3 with uv on ALL platforms.
# .py modify scripts use the shebang on Unix; this entry runs them on Windows
# (where shebangs are ignored). Must be unconditional — without it, .py is not
# stripped from target names on Linux/Mac (→ e.g. ~/.claude.json.py).
# Replaces `json = {uv}` (removed): that caused modify_private_dot_claude.json to
# lose its .json extension on Windows → target ~/.claude → collision with dot_claude/.
[interpreters]
py = { command = "uv", args = ["run", "--script", "--no-project"] }
{{- if $is_windows }}
sh = { command = 'C:\Program Files\Git\bin\bash.exe' }
{{- end }}

[hooks.read-source-state.pre]
{{- if $is_darwin }}
command = ".local/share/chezmoi/.bootstrap.darwin.sh"
{{- else if $is_linux }}
command = ".local/share/chezmoi/.bootstrap.linux.sh"
args = [{{ .chezmoi.osRelease.id | quote }}]
{{- else if $is_windows }}
command = "powershell"
args = ["-NoProfile", ".local/share/chezmoi/.bootstrap.windows.ps1", {{ $wsl_distro | quote }}]
{{- end }}

[onepassword]
mode = "service"

[scriptEnv]
PATH = "{{ $all_paths | join .chezmoi.pathListSeparator | replace "\\" "/" }}"
MISE_GITHUB_TOKEN = {{ $my_github_token | quote }}
OP_SERVICE_ACCOUNT_TOKEN = {{ $op_token | quote }}
{{- if $is_riot_machine }}
MISE_GITHUB_ENTERPRISE_TOKEN = {{ $riot_github_token | quote }}
{{- end }}
