{{- $userLocalDir := joinPath .chezmoi.homeDir ".local" }}
{{- $localMyDir := joinPath $userLocalDir "my" }}
{{- $localShareDir := joinPath $userLocalDir "share" }}

{{- $dropboxDir := joinPath .chezmoi.homeDir "Dropbox" }}

dropbox {{ $dropboxDir }}
notes {{ joinPath $dropboxDir "notes" }}

chez {{ .chezmoi.sourceDir }}
dot {{ joinPath .chezmoi.homeDir ".dotfiles" }}

{{- $codeDir := joinPath .chezmoi.homeDir "Code" }}
{{- $codePlaygroundDir := joinPath $codeDir "playground" }}

code {{ $codeDir }}
www {{ joinPath $codeDir "dysfungi.github.io" }}
playground {{ $codePlaygroundDir }}
goground {{ joinPath $codePlaygroundDir "go" }}
pyground {{ joinPath $codePlaygroundDir "python" }}

{{- if .is_riot_machine }}

jira {{ joinPath $localMyDir "jira" }}
riot-slack {{ joinPath $localMyDir "riot-slack" }}

reliability {{ joinPath $codeDir "reliability-infrastructure" }}

lime {{ joinPath $codeDir "lime-monorepo" }}

lol {{ joinPath $codeDir "keystone-products.league-of-legends" }}

{{- $perforceDir := .is_wsl | ternary "/mnt/t/p4" (joinPath .chezmoi.homeDir "Perforce") }}
{{- $flxDir := joinPath $perforceDir "flyingfox" "dev-main" }}
{{- $lionDir := joinPath $perforceDir "lion" "dev-main" }}

p4 {{ $perforceDir }}
flyingfox {{ $flxDir }}
flx {{ $flxDir }}
lion {{ $lionDir }}
2xko {{ $lionDir }}
{{- if .is_darwin }}

main /Users/shared/p4/depot/LoL/__MAIN__/
devroot /Users/shared/p4/depot/LoL/__MAIN__/DevRoot
lcu /Users/shared/p4/depot/LoL/__MAIN__/DevRoot/Client

{{- end }}

{{- else }}

{{- $monorepoDir := joinPath $codeDir "monorepo" }}
{{- $fsharpDir := joinPath $monorepoDir "fsharp" }}
{{- $terraformDir := joinPath $monorepoDir "terraform" }}

monorepo {{ $monorepoDir }}
fsharp {{ $fsharpDir }}
fsharp-api {{ joinPath $fsharpDir "api" }}
automate-api {{ joinPath $fsharpDir "api" "automate" }}
terraform {{ $terraformDir }}
infrastructure {{ joinPath $terraformDir "infrastructure" }}
frankenstructure {{ joinPath $terraformDir "infrastructure" "frankenstructure" }}
gateway {{ joinPath $terraformDir "infrastructure" "gateway" }}
monitoring {{ joinPath $terraformDir "infrastructure" "monitoring" }}
observability {{ joinPath $terraformDir "infrastructure" "observability" }}
modules {{ joinPath $terraformDir "modules" }}
route {{ joinPath $terraformDir "modules" "gateway-route" }}
postgres {{ joinPath $terraformDir "modules" "vultr-managed-postgres" }}
probes {{ joinPath $terraformDir "modules" "blackbox-probe" }}
applications {{ joinPath $terraformDir "applications" }}
httpbin {{ joinPath $terraformDir "applications" "httpbin" }}
miniflux {{ joinPath $terraformDir "applications" "miniflux" }}
ollama {{ joinPath $terraformDir "applications" "ollama" }}

{{- end }}
