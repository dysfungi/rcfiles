# pi agent externals (namespaced to ~/.pi/agent/ — entries below are resolved
# relative to this file's target directory).
#
# Note: chezmoi does not support subdirectories inside `.chezmoiexternals/`
# (see chezmoi#4274), so per-namespace externals live colocated with their
# target directory via `.chezmoiexternal.<format>` instead.

# shell-quote parser for the plan-mode extension's read-only bash analysis.
#
# Vendored as a single self-contained file (zero deps, 6.3 KB) so plan-mode can
# tokenize bash robustly (quoting/escaping/redirects) instead of relying solely
# on regex. chezmoi fetches + auto-refreshes it (TTL) so there is nothing to
# install or maintain: no package.json, no npm install, no node_modules.
#
# Pinned to major `@1` (jsdelivr resolves to latest 1.x) — parse() output shape
# is stable across 1.x, and TTL refresh keeps it current with zero upkeep.
# Named .cjs because parse.js is CommonJS (module.exports); plan-mode imports it
# relatively. If this file is absent (e.g. offline first apply), the extension
# uses its shared built-in quote-aware tokenizer. See
# extensions/plan-mode/{DESIGN.md,bash-safety.ts}.
["extensions/plan-mode/vendor/shell-quote-parse.cjs"]
type = "file"
url = "https://cdn.jsdelivr.net/npm/shell-quote@1/parse.js"
refreshPeriod = "720h"
