# Provision Arch Linux WSL distro: create user, install core packages, set as default.
# Idempotent — runs on every chezmoi apply (run_before); guards exit early when already set up.

$ErrorActionPreference = "Stop"
Write-Host "INFO: Starting $PSCommandPath"

$ErrorActionPreference = "Continue"
wsl -d {{ .wsl_distro }} -- echo ok 2>$null
$ErrorActionPreference = "Stop"
if ($LASTEXITCODE -ne 0) {
    Write-Host "Arch Linux WSL distro not available. Skipping."
    Write-Host "INFO: Ending $PSCommandPath"
    exit 0
}

$ErrorActionPreference = "Continue"
wsl -d {{ .wsl_distro }} -u root -- bash -c "grep -q '^ID=arch$' /etc/os-release" 2>$null
$ErrorActionPreference = "Stop"
if ($LASTEXITCODE -ne 0) {
    Write-Host "WSL distro '{{ .wsl_distro }}' is not Arch Linux (ID!=arch in /etc/os-release). Skipping Arch setup."
    Write-Host "INFO: Ending $PSCommandPath"
    exit 0
}

Write-Host "Initializing pacman keyring in Arch Linux WSL..."
wsl -d {{ .wsl_distro }} -u root -- bash -c "pacman-key --init && pacman-key --populate archlinux"

Write-Host "Installing core packages in Arch Linux WSL..."
wsl -d {{ .wsl_distro }} -u root -- bash -c "pacman -Syu --noconfirm --needed base-devel git chezmoi openssh inetutils tmux unzip curl"

Write-Host "Installing 1Password CLI in Arch Linux WSL..."
$opInstallScript = @'
#!/usr/bin/env bash
set -e
command -v op >/dev/null 2>&1 && exit 0
arch=amd64; case $(uname -m) in aarch64) arch=arm64;; esac
ver=$(curl -s https://app-updates.agilebits.com/check/1/0/CLI2/en/2.0.0/N | sed 's/.*"version":"\([0-9.]*\)".*/\1/')
url="https://cache.agilebits.com/dist/1P/op2/pkg/v${ver}/op_linux_${arch}_v${ver}.zip"
curl -sSfo /tmp/op.zip "$url"
unzip -o /tmp/op.zip op -d /usr/local/bin
chmod +x /usr/local/bin/op
rm /tmp/op.zip
echo "INFO: Installed op v${ver} ${arch}"
'@
$tmpScript = [System.IO.Path]::GetTempFileName() + ".sh"
[System.IO.File]::WriteAllText($tmpScript, $opInstallScript.Replace("`r`n", "`n"), [System.Text.UTF8Encoding]::new($false))
$wslPath = wsl -d {{ .wsl_distro }} -- wslpath ($tmpScript -replace '\\','/')
wsl -d {{ .wsl_distro }} -u root -- bash $wslPath
Remove-Item $tmpScript -ErrorAction SilentlyContinue
if ($LASTEXITCODE -ne 0) {
    Write-Error "FATAL: 1Password CLI install failed in Arch Linux WSL."
    exit 1
}

# Check if user exists — stderr from `id` triggers NativeCommandError in PS 5.1
# with ErrorActionPreference=Stop, so temporarily relax it
$ErrorActionPreference = "Continue"
wsl -d {{ .wsl_distro }} -u root -- id {{ .username }} 2>$null
$ErrorActionPreference = "Stop"
if ($LASTEXITCODE -ne 0) {
    Write-Host "Creating WSL user '{{ .username }}'..."
    # [boot] systemd=true is required for cronie (the cron daemon) to run in WSL.
    # Without it, cron jobs registered by the stage-90 install-update-cron script
    # will never fire. Include both [boot] and [user] sections on first write.
    wsl -d {{ .wsl_distro }} -u root -- bash -c "set -e; useradd -m -G wheel {{ .username }}; passwd -l {{ .username }}; printf '[boot]\nsystemd=true\n[user]\ndefault={{ .username }}\n' > /etc/wsl.conf; echo '%wheel ALL=(ALL:ALL) NOPASSWD: ALL' > /etc/sudoers.d/wheel; chmod 0440 /etc/sudoers.d/wheel"
    if ($LASTEXITCODE -ne 0) {
        Write-Error "FATAL: WSL user creation failed."
        exit 1
    }
    wsl --terminate {{ .wsl_distro }}
    Write-Host "WSL user '{{ .username }}' created. Distro restarted."
} else {
    Write-Host "WSL user '{{ .username }}' already exists."
}

# Ensure systemd is enabled in wsl.conf (idempotent; needed for cronie).
# Already-provisioned machines that pre-date this change need this update.
$ErrorActionPreference = "Continue"
wsl -d {{ .wsl_distro }} -u root -- bash -c "grep -q 'systemd=true' /etc/wsl.conf" 2>$null
$ErrorActionPreference = "Stop"
if ($LASTEXITCODE -ne 0) {
    Write-Host "Adding [boot] systemd=true to WSL /etc/wsl.conf..."
    wsl -d {{ .wsl_distro }} -u root -- bash -c "printf '\n[boot]\nsystemd=true\n' >> /etc/wsl.conf"
    wsl --terminate {{ .wsl_distro }}
    Write-Host "WSL restarted to apply systemd=true."
} else {
    Write-Host "WSL systemd already enabled."
}

wsl --set-default {{ .wsl_distro }}
Write-Host "Arch Linux is the default WSL distro."
Write-Host "INFO: Ending $PSCommandPath"
