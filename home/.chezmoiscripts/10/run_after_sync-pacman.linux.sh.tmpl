#!/usr/bin/env bash
# Sync pacman packages in Arch Linux (WSL or otherwise).
# Reads pacman: fields from .chezmoidata/packages.yaml. AUR packages (aur: field) are handled by sync-yay.
# Idempotent — safe to re-run.
#
# Privileged calls use chezmoi-sudo instead of bare sudo so that unattended daily
# cron runs (via chezmoi-update-cron) can skip gracefully instead of blocking on a
# password prompt. chezmoi-sudo falls back through: cached creds → interactive TTY
# → SUDO_ASKPASS (1Password) → WARN+skip. See ~/.local/bin/chezmoi-sudo for details.

set -euo pipefail

echo >&2 "INFO: Starting $0"

if ! command -v pacman >/dev/null 2>&1; then
  echo >&2 "WARNING: pacman not found; skipping."
  echo >&2 "INFO: Ending $0"
  exit 0
fi

userName="$(whoami)"
hostName="$(hostname)"
bakSuffix="${userName}.${hostName}"
bakDir="${CHEZMOI_WORKING_TREE}/.backups"
bakFile="${bakDir}/pacman-packages.${bakSuffix}"

mkdir -p "${bakDir}"

_commit_backup() {
  local clarifier="${1:?required}"
  local action="${2:?required}"

  local -x GIT_DIR="${CHEZMOI_WORKING_TREE}/.git"
  local -x GIT_WORK_TREE="${CHEZMOI_WORKING_TREE}"

  git add "${bakFile}"
  if ! git diff --cached --quiet -- "${bakDir}"; then
    git commit --no-verify --message "chore(backups): List pacman packages ${clarifier} ${action} for ${userName} on ${hostName}" -- "${bakDir}"
  fi
}

backup() {
  local clarifier="${1:?required}"
  local action="${2:?required}"

  chezmoi-sudo pacman -Qqe | sort >"${bakFile}"

  _commit_backup "${clarifier}" "${action}"
}

{{ $packages := list }}
{{- range $name, $pkg := .my.packages }}
  {{- if hasKey $pkg "pacman" }}
    {{- $packages = append $packages (printf "%s" $pkg.pacman) }}
  {{- end }}
{{- end }}
{{- if .is_riot_machine }}
  {{- range $name, $pkg := .riot.packages }}
    {{- if hasKey $pkg "pacman" }}
      {{- $packages = append $packages (printf "%s" $pkg.pacman) }}
    {{- end }}
  {{- end }}
{{- end -}}

declared_packages="{{ join " " $packages }}"

backup before install

if [ -n "$declared_packages" ]; then
  echo >&2 "INFO: Installing declared pacman packages..."
  # shellcheck disable=SC2086
  chezmoi-sudo pacman -Syu --noconfirm --needed $declared_packages
fi

backup after install

echo >&2 "INFO: Cleaning pacman cache..."
chezmoi-sudo paccache -rk2 && chezmoi-sudo paccache -ruk0

echo >&2 "INFO: pacman sync complete."
echo >&2 "INFO: Ending $0"
