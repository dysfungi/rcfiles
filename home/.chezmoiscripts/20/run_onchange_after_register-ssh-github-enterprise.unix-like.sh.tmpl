{{- if .is_riot_machine -}}
#!/usr/bin/env bash
# Register this machine's SSH public key with Riot's GitHub Enterprise Server
# (gh.riotgames.com). Scoped to Riot machines only; no-op elsewhere.
#
# run_onchange_ keyed on the live public key below so it re-registers whenever the
# key rotates (run_once_ never re-ran after a key change).
#
# pubkey: {{ if stat (printf "%s/.ssh/id_ed25519.pub" .chezmoi.homeDir) }}{{ output "cat" (printf "%s/.ssh/id_ed25519.pub" .chezmoi.homeDir) }}{{ end }}
set -euo pipefail

echo >&2 "INFO: Starting $0"

{{ includeTemplate "github/register-ssh-key.sh" }}
register_ssh_key "gh.riotgames.com" "${MISE_GITHUB_ENTERPRISE_TOKEN}"

echo >&2 "INFO: Ending $0"
{{ end -}}
