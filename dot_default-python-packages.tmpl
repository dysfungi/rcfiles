{{ range $name, $pkg := .riot.packages -}}
{{ if hasKey $pkg "pip" -}}
{{ $pkg.pip }}
{{ end -}}
{{ end -}}
{{ range $name, $pkg := .riot.packages -}}
{{ if not (hasKey $pkg "xontrib") -}} {{ continue }} {{- end -}}
{{ $pkg.xontrib }}
{{ end -}}
{{ end -}}
