#!/usr/bin/env bash
# chezmoi-update-cron: daily unattended dotfile auto-update runner.
#
# Design:
#   Invoked by cron once per day (registered by the stage-90 install script).
#   Cron provides a minimal environment with no interactive TTY and a stripped PATH.
#   This script reconstructs the environment needed by chezmoi and its chezmoiscripts,
#   then runs `mise x -- chezmoi update --init --verbose --keep-going`.
#
#   Key behaviours:
#     - PATH: mirrors [scriptEnv] PATH from .chezmoi.toml.tmpl so all tools are reachable.
#     - 1Password token: injected by `mise x` from the static [env] table in
#       ~/.config/mise/conf.d/secrets.toml (no exec templates, so mise can never
#       abort on env resolution). If mise is missing, this script fails loudly.
#     - SUDO_ASKPASS: set to chezmoi-askpass so privileged chezmoiscripts can call
#       `chezmoi-sudo` which in turn uses `sudo -A` for unattended password supply.
#       Homebrew's internal sudo ignores SUDO_ASKPASS; new privileged casks should
#       be installed via an interactive `chezmoi apply` instead.
#     - Lock: mkdir-based (portable; macOS lacks flock). Prevents overlapping runs
#       (e.g. machine wakes during a previous missed-run catch-up that never completed).
#     - Two-channel output: everything goes to the log (full detail); nag-worthy
#       drift/failure summaries additionally go to fd 3 — the saved original
#       stderr — which cron captures and mails to the crontab owner
#       (/var/mail/$USER). A clean run writes nothing to fd 3, so no mail.
#     - Log: appended to ~/.local/state/chezmoi/update-cron.log, rotated weekly by
#       the stage-65 logrotate config (dot_config/logrotate/chezmoi.conf).
#
#   Caveats documented in README "Automatic updates":
#     - Plain cron doesn't catch up missed runs (no PowerNap / wakeup-on-idle like launchd).
#     - macOS cron requires Full Disk Access once (System Settings → Privacy & Security).
#     - Homebrew privileged cask installs may be skipped; add them interactively.

set -euo pipefail

# ── environment ──────────────────────────────────────────────────────────────

# Mirror [scriptEnv] PATH from .chezmoi.toml.tmpl. Template variable substitution
# makes this self-consistent when the file is rendered by chezmoi.
export PATH="{{ .path_str }}"

ASKPASS="${HOME}/.local/bin/chezmoi-askpass"
export SUDO_ASKPASS="${ASKPASS}"

# OP_SERVICE_ACCOUNT_TOKEN is delivered by `mise x` (see run block) from the
# static [env] table in ~/.config/mise/conf.d/secrets.toml. chezmoi-askpass
# inherits it too: `sudo -A` execs the askpass helper as the invoking user
# before env_reset strips the environment.

# ── lock ─────────────────────────────────────────────────────────────────────

LOCK_DIR="${HOME}/.local/state/chezmoi/update-cron.lock"
# Ensure the parent state dir exists first: bare `mkdir` of the lock fails on
# a missing parent too, which would masquerade as "another run in progress"
# and silently skip the update forever on a fresh machine.
mkdir -p "${LOCK_DIR%/*}"
if ! mkdir "${LOCK_DIR}" 2>/dev/null; then
  echo >&2 "INFO: chezmoi-update-cron: another run is in progress (${LOCK_DIR}); exiting."
  exit 0
fi
# Always remove the lock on exit, even on error.
trap 'rm -rf "${LOCK_DIR}"' EXIT

# ── logging ──────────────────────────────────────────────────────────────────

LOG_DIR="${HOME}/.local/state/chezmoi"
LOG_FILE="${LOG_DIR}/update-cron.log"
mkdir -p "${LOG_DIR}"

# Save the original stderr as fd 3 — the mail channel: cron mails any job
# output to the crontab owner, landing in /var/mail/$USER, which shell mail
# checks surface as "You have (new) mail.". Write
# ONLY nag-worthy summaries to >&3 — a clean run must stay silent there so
# no mail is sent.
exec 3>&2
exec >>"${LOG_FILE}" 2>&1

# Guarded AFTER the log redirect so the full ERROR lands in the log file;
# a one-line summary also goes to the mail channel so the failure is nagged,
# not buried. Nothing above this point needs mise (PATH/askpass exports,
# lock, log setup).
if ! command -v mise >/dev/null 2>&1; then
  echo >&2 "ERROR: chezmoi-update-cron: mise not on PATH; cannot deliver OP_SERVICE_ACCOUNT_TOKEN."
  echo >&3 "chezmoi-update-cron: mise not on PATH; update did not run. See ${LOG_FILE}"
  exit 1
fi

# ── run ──────────────────────────────────────────────────────────────────────

echo "INFO: Starting chezmoi-update-cron at $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
echo "INFO: hostname=$(hostname) user=$(whoami)"

# mise x injects OP_SERVICE_ACCOUNT_TOKEN from the static conf.d/secrets.toml
# [env]; --init then re-renders .chezmoi.toml.tmpl with the token present.
# --keep-going: this run is unattended (no TTY), so chezmoi's overwrite prompt
# would fail with "could not open a new TTY" and abort the apply mid-run.
# Drift is EXPECTED here — Claude Code perpetually rewrites its own settings
# files (modify_ targets like ~/.claude/settings.json) — so drifted targets
# are skipped, letting the rest of the apply converge. Never force-overwrite
# from this unattended path: out-of-band edits are deliberate and a human must
# resolve them (drift is surfaced via cron mail in the report below).
rc=0
mise x -- chezmoi update --init --verbose --keep-going 3>&- || rc=$?

# ── report ───────────────────────────────────────────────────────────────────

# Failure notice FIRST, drift second, both set-e-guarded: a broken
# `chezmoi status` (plausibly correlated with a broken update) must never
# silently eat the failure notice.
if ((rc != 0)); then
  echo >&3 "chezmoi-update-cron: chezmoi update exited rc=${rc}; see ${LOG_FILE}"
fi

# Drift detection: `chezmoi status` is read-only and never prompts. An M in
# either column ≈ the drift-class statuses; the pattern also matches
# source-changed `M ` lines (harmless: an extra listing, never a false
# prompt). substr($0, 4) keeps target paths containing spaces intact.
# 3>&- closes the mail channel for the child (same hygiene as the run line).
if ! drift="$(mise x -- chezmoi status 3>&- | awk '$1 ~ /M/ { print substr($0, 4) }')"; then
  echo >&3 "chezmoi-update-cron: chezmoi status failed; see ${LOG_FILE}"
elif [[ -n "${drift}" ]]; then
  # Full detail to the log (stderr → log); concise summary to fd 3 → cron
  # mail → /var/mail/$USER.
  drift_count="$(awk 'END { print NR }' <<<"${drift}")"
  echo >&2 "ERROR: chezmoi-update-cron: ${drift_count} drifted target(s) skipped by --keep-going:"
  while IFS= read -r target; do
    echo >&2 "ERROR:   ${target}"
  done <<<"${drift}"
  {
    echo "chezmoi-update-cron: ${drift_count} drifted target(s) skipped (--keep-going):"
    while IFS= read -r target; do
      echo "  ${target}"
    done <<<"${drift}"
    echo "fix with: chezmoi diff <target> && chezmoi apply --force <target>"
  } >&3
fi

echo "INFO: Ending chezmoi-update-cron at $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
exit "${rc}"
