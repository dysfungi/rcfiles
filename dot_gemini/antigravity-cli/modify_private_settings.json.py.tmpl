#!/usr/bin/env -S uv run --script --no-project
# vim: ft=gotmpl.python
"""
Manages ~/.gemini/antigravity-cli/settings.json (the Antigravity CLI's own config).

WHY A modify_ SCRIPT (not a plain managed file):
    agy mixes durable user preferences (enableTelemetry, enableTerminalSandbox,
    toolPermission) with runtime state in the same file — notably
    trustedWorkspaces, which agy rewrites whenever the user trusts a folder. A
    plain managed file would clobber that runtime key on every `chezmoi apply`.
    A modify_ script reads the current target on stdin and emits the merged
    result on stdout, so it enforces our prefs while preserving everything agy
    maintains there.

WHY THESE KEYS (agy ignores the shared gemini-cli settings.json; native ports
    go here — see Phase 3 of the Gemini->Antigravity migration):
      - enableTelemetry=False        — opt out of usage telemetry.
      - enableTerminalSandbox=True   — run shell tools inside agy's sandbox.
      - toolPermission="proceed-in-sandbox" — auto-proceed for sandboxed tools,
        but still gate anything that escapes the sandbox.

The Go-template head injects raw chezmoidata (homeDir, projects) into Python
constants; all transformation and merge logic below is plain stdlib Python. The
`.py` interpreter extension is what chezmoi strips from the target name (see
`[interpreters]` in .chezmoi.toml.tmpl); the `private_` attribute preserves
agy's 0600 permissions on the target.
"""
import json
import sys
from pathlib import Path

HOME_DIR = Path({{ .chezmoi.homeDir | quote }})
PROJECTS: list = json.loads({{ concat .my.projects (ternary .riot.projects (list) .is_riot_machine) | mustToJson | quote }})


def resolve_project_path(project: dict) -> str:
    path = project["path"]
    return str(HOME_DIR / path) if project.get("is_home_relative") else path


def update_trusted_workspaces(config: dict) -> None:
    trusted_workspaces = set(config.setdefault("trustedWorkspaces", []))
    trusted_workspaces.update(map(resolve_project_path, PROJECTS))
    config["trustedWorkspaces"] = sorted(trusted_workspaces)


def main() -> None:
    stdin = sys.stdin.read().strip()
    config = json.loads(stdin) if stdin else {}

    update_trusted_workspaces(config)
    config.update({
        "allowNonWorkspaceAccess": True,
        "enableTelemetry": False,
        "enableTerminalSandbox": True,
        "notifications": True,
        "permissions": {
            "deny": [
                "command(git push -f)",
                "command(git push --force)",
                "command(rm -rf /)",
            ],
        },
        "runningLightSpeed": "slow",
        "showFeedbackSurvey": False,
        "toolPermission": "always-proceed",  # "proceed-in-sandbox",
    })

    print(json.dumps(config, indent=2, sort_keys=True))


if __name__ == "__main__":
    main()
