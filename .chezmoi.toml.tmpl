[data]
name = "Derek M Frank"

isBsd = {{ eq .chezmoi.os "freebsd" "openbsd" }}
isDarwin = {{ eq .chezmoi.os "darwin" }}
isLinux = {{ eq .chezmoi.os "linux" }}
isMac = {{ eq .chezmoi.os "darwin" }}
isUnixLike = {{ eq .chezmoi.os "darwin" "freebsd" "linux" "openbsd" "unix" }}
isWindows = {{ eq .chezmoi.os "windows" }}

{{ $isMyMachine := eq .chezmoi.username "dmf" -}}
{{ $isWorkMachine := not $isMyMachine -}}
{{ $isRiotMachine := eq .chezmoi.username "dfrank" "RIOTGAMES\\dfrank" "RIOTGAMES+dfrank" -}}
{{ if or (eq $isMyMachine $isWorkMachine $isRiotMachine) (ne $isWorkMachine $isRiotMachine) -}}
  {{ fail "Failed to determine machine ownership" -}}
{{ end -}}
email = {{ $isRiotMachine | ternary "dfrank@riotgames.com" "derek@frank.sh" | quote }}
isMyMachine = {{ $isMyMachine }}
isWorkMachine = {{ $isWorkMachine }}
isRiotMachine = {{ $isRiotMachine }}

{{- if $isRiotMachine }}
riotGithubToken = {{ onepasswordRead "op://Riot/GitHub - Personal Access Token/password" | quote }}
{{- end }}

{{ $opToken := env "OP_SERVICE_ACCOUNT_TOKEN" -}}
{{ $opTokenFile := joinPath .chezmoi.homeDir ".secrets" "OP_SERVICE_ACCOUNT_TOKEN" -}}
{{ if not $opToken -}}
  {{ if stat $opTokenFile -}}
    {{ $opToken = include $opTokenFile | trim -}}
  {{ else -}}
    {{ $opToken = promptString "1Password service account token" -}}
  {{ end -}}
{{ end -}}
opServiceAccountToken = {{ $opToken | quote }}

[cd]
args = [
    # "--rc=~/.config/xonsh/rc.xsh",
    # "--rc=~/.config/xonsh/rc.d/mise.xsh",
    # "-DXONSH_DEBUG=1",
    # "-DXONSH_SHOW_TRACEBACK=1",
    # "-DXONSH_TRACE_SUBPROC=2",
]

[diff]
exclude = ["scripts"]

[hooks.read-source-state.pre]
{{- if eq .chezmoi.os "windows" }}
command = "powershell"
args = ["-NoProfile", ".local/share/chezmoi/.bootstrap.windows.ps1"]
{{- else if eq .chezmoi.os "darwin" }}
command = ".local/share/chezmoi/.bootstrap.darwin.sh"
{{- else if eq .chezmoi.os "linux" }}
command = ".local/share/chezmoi/.bootstrap.linux.sh"
{{- end }}

[onepassword]
mode = "service"

[interpreters.sh]
{{- if eq .chezmoi.os "windows" }}
command = "C:\\Program Files\\Git\\bin\\bash.exe"
{{- end }}

[github]
token = {{ onepasswordRead "op://CLI/GitHub Token - Chezmoi/password" | quote }}

[scriptEnv]
MISE_GITHUB_TOKEN = {{ onepasswordRead "op://CLI/GitHub Token - Chezmoi/password" | quote }}
