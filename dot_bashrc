if [ -f "$HOME/.config/sh/load-secrets.sh" ]; then
  . "$HOME/.config/sh/load-secrets.sh"
fi

# https://mise.jdx.dev/shells.html#bash
if command -v mise >/dev/null 2>&1; then
  if [ -n "${MSYSTEM:-}" ]; then
    # Full activation adds PROMPT_COMMAND hooks that conflict with `bash -i -c` in WezTerm.
    # --shims adds the shims dir to PATH without hooks (sufficient for Git Bash sessions).
    # $MSYSTEM (MINGW64, MINGW32, MSYS) is set by MSYS2/Git Bash and never by WSL2 or Linux.
    eval "$(mise activate bash --shims)"
  else
    eval "$(mise activate bash)"
  fi
fi
