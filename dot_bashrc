# Deliver mise [env] vars (incl. ~/.config/mise/conf.d/secrets.toml) to bash.
command -v mise >/dev/null 2>&1 && eval "$(mise env -s bash)"

# https://mise.jdx.dev/shells.html#bash
# MISE_SHELL is exported by mise activate; skip if .profile already ran it (login shells)
if command -v mise >/dev/null 2>&1 && [ -z "${MISE_SHELL:-}" ]; then
  eval "$(mise activate bash --shims)"
fi
