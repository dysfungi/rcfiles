#!/usr/bin/env bash
set -euo pipefail

# Target directory for your Modelfiles
TARGET_DIR="{{ $.chezmoi.homeDir }}/.local/share/ollama-agents"
mkdir -p "$TARGET_DIR"

{{- if $.isMyMachine }}

{{- range $modelNameWithTag, $model := .my.models }}
{{- if not (default false .enabled) }}{{ continue }}{{- end }}

{{- $_ := set $model "nameWithTag" $modelNameWithTag }}
{{- $_ := set $model "safeName" ($modelNameWithTag | replace ":" "__") }}
{{- $_ := set $model "nameParts" (splitn ":" 2 $modelNameWithTag) }}
{{- $_ := set $model "name" $model.nameParts._0 }}
{{- $_ := set $model "tag" (default (default "latest" (get $model "tag")) $model.nameParts._1) }}

# ---------------------------------------------------------
# Generating Modelfile for: {{ $model.nameWithTag }}
# ---------------------------------------------------------
FILE_PATH="$TARGET_DIR/Modelfile-{{ $model.safeName }}"

cat <<-EOF >"$FILE_PATH"
{{ includeTemplate ".chezmoitemplates/ollama/Modelfile.tmpl" $model -}}
EOF

echo "Generated: $FILE_PATH"

# Optional: You can also tell Ollama to build it immediately
ollama create "local__{{ $model.safeName }}" -f "$FILE_PATH"

{{- end }}

{{- end }}
