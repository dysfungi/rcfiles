#!/usr/bin/env bash
set -euo pipefail

echo >&2 "INFO: Starting $0"

MAMBA_PYTHON="$HOME/.local/xonsh-env/bin/python"
if [ ! -f "$MAMBA_PYTHON" ]; then
  echo >&2 "WARNING: Mamba xonsh Python not found at $MAMBA_PYTHON; skipping xontrib sync"
  exit 0
fi

userName="$(whoami)"
hostName="$(hostname)"
bakSuffix="${userName}.${hostName}"
bakDir="${CHEZMOI_SOURCE_DIR}/.backups"
bakFile="${bakDir}/xontrib-freeze.${bakSuffix}"

mkdir -p "${bakDir}"

_commit_backup() {
  local clarifier="${1:?required}"
  local action="${2:?required}"

  local -x GIT_DIR="${CHEZMOI_SOURCE_DIR}/.git"
  local -x GIT_WORK_TREE="${CHEZMOI_WORKING_TREE}"

  git add "${bakFile}"
  if ! git diff --cached --quiet -- "${bakDir}"; then
    git commit --message "chore(backups): Freeze xontrib packages ${clarifier} ${action} for ${userName} on ${hostName}" -- "${bakDir}"
  fi
}

backup() {
  local clarifier="${1:?required}"
  local action="${2:?required}"

  UV_PYTHON="${MAMBA_PYTHON}" uv pip freeze >"${bakFile}"

  _commit_backup "${clarifier}" "${action}"
}

xontribs=(
{{ range $name, $pkg := .my.packages -}}
{{ if not (hasKey $pkg "xontrib") -}} {{ continue }} {{- end -}}
{{ printf "  %s" $pkg.xontrib }}
{{ end -}}
{{ if .isRiotMachine -}}
{{ range $name, $pkg := .riot.packages -}}
{{ if not (hasKey $pkg "xontrib") -}} {{ continue }} {{- end -}}
{{ printf "  %s" $pkg.xontrib }}
{{ end -}}
{{ end -}}
)

backup before install
UV_PYTHON="${MAMBA_PYTHON}" uv pip install --upgrade "${xontribs[@]}"
backup after install

echo >&2 "INFO: Ending $0"
