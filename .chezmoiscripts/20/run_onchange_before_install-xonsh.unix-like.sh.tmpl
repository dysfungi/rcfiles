#!/usr/bin/env bash
set -euo pipefail

echo >&2 "INFO: Starting $0"

export PYTHON_VER={{ (index .my.packages "xonsh").python }}
export TARGET_DIR="$HOME/.local/xonsh-env"
export XONSH_VER='{{ (index .my.packages "xonsh").mamba }}'

# The upstream installer appends $XONSHRC to ~/.xonshrc when non-empty. Running
# from a xonsh session, $XONSHRC is the inherited ':'-joined RC-list, producing
# a broken ~/.xonshrc. Force it empty so that block is skipped.
export XONSHRC=''

# https://xon.sh/install_mamba.html
# ln -sf so re-runs (eg, version upgrades) don't fail on existing symlinks
curl -fsSL https://xon.sh/install/mamba-install-xonsh.sh |
  sed 's|ln -s |ln -sf |g' |
  bash

echo >&2 "INFO: Ending $0"
