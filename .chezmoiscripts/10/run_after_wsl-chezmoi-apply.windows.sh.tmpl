#!/usr/bin/env bash
set -euo pipefail

echo >&2 "INFO: Starting $0"

if ! wsl.exe -d archlinux -- command -v chezmoi >/dev/null 2>&1; then
  echo >&2 "WARN: chezmoi not available in WSL archlinux. Skipping."
  echo >&2 "INFO: Ending $0"
  exit 0
fi

export OP_SERVICE_ACCOUNT_TOKEN={{ .opServiceAccountToken | quote }}
export GITHUB_TOKEN={{ .githubToken | quote }}
export WSLENV="OP_SERVICE_ACCOUNT_TOKEN:GITHUB_TOKEN"

if wsl.exe -d archlinux -- bash -c 'test -d ~/.local/share/chezmoi'; then
  echo >&2 "INFO: Updating chezmoi in WSL..."
  wsl.exe -d archlinux -- chezmoi update
else
  echo >&2 "INFO: Initializing chezmoi in WSL..."
  # chezmoi init needs onepassword.mode=service before the config template renders
  wsl.exe -d archlinux -- bash -c 'printf "[onepassword]\nmode = \"service\"\n" > /tmp/chezmoi-bootstrap.toml && chezmoi init --apply -c /tmp/chezmoi-bootstrap.toml https://github.com/dysfungi/rcfiles.git; rm -f /tmp/chezmoi-bootstrap.toml'
fi

echo >&2 "INFO: Ending $0"
