#!/usr/bin/env bash
set -euo pipefail

echo >&2 "INFO: Starting $0"

if ! wsl.exe -d archlinux -- command -v chezmoi >/dev/null 2>&1; then
  echo >&2 "WARN: chezmoi not available in WSL archlinux. Skipping."
  echo >&2 "INFO: Ending $0"
  exit 0
fi

export OP_SERVICE_ACCOUNT_TOKEN={{ .opServiceAccountToken | quote }}
export CHEZMOI_ONEPASSWORD_MODE=service
export WSLENV="OP_SERVICE_ACCOUNT_TOKEN:CHEZMOI_ONEPASSWORD_MODE"

if wsl.exe -d archlinux -- test -d ~/.local/share/chezmoi; then
  echo >&2 "INFO: Updating chezmoi in WSL..."
  wsl.exe -d archlinux -- chezmoi apply
else
  echo >&2 "INFO: Initializing chezmoi in WSL..."
  wsl.exe -d archlinux -- chezmoi init --apply https://github.com/dysfungi/rcfiles.git
fi

echo >&2 "INFO: Ending $0"
