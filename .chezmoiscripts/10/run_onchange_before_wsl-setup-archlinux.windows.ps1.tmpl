# Provision Arch Linux WSL distro: create user, install core packages, set as default.
# Idempotent — safe to re-run when script content changes (run_onchange).

$ErrorActionPreference = "Stop"
Write-Host "INFO: Starting $PSCommandPath"

$ErrorActionPreference = "Continue"
wsl -d archlinux -- echo ok 2>$null
$ErrorActionPreference = "Stop"
if ($LASTEXITCODE -ne 0) {
    Write-Host "Arch Linux WSL distro not available. Skipping."
    Write-Host "INFO: Ending $PSCommandPath"
    exit 0
}

Write-Host "Setting up 1Password CLI repo in Arch Linux WSL..."
wsl -d archlinux -u root -- bash -c "grep -q '^\[1password\]' /etc/pacman.conf || (curl -sS https://downloads.1password.com/linux/keys/1password.asc | pacman-key --add - && pacman-key --lsign-key 3FEF9748469ADBE15DA7CA80AC2D62742012EA22 && printf '[1password]\nSigLevel = TrustAll\nServer = https://downloads.1password.com/linux/arch/aarch64\n' >> /etc/pacman.conf)"

Write-Host "Installing core packages in Arch Linux WSL..."
wsl -d archlinux -u root -- bash -c "pacman -Syu --noconfirm --needed base-devel git chezmoi tmux 1password-cli"
if ($LASTEXITCODE -ne 0) {
    Write-Error "FATAL: pacman install failed in Arch Linux WSL."
    exit 1
}

# Check if user exists — stderr from `id` triggers NativeCommandError in PS 5.1
# with ErrorActionPreference=Stop, so temporarily relax it
$ErrorActionPreference = "Continue"
wsl -d archlinux -u root -- id {{ .username }} 2>$null
$ErrorActionPreference = "Stop"
if ($LASTEXITCODE -ne 0) {
    Write-Host "Creating WSL user '{{ .username }}'..."
    wsl -d archlinux -u root -- bash -c "set -e; useradd -m -G wheel {{ .username }}; passwd -l {{ .username }}; printf '[user]\ndefault={{ .username }}\n' > /etc/wsl.conf; echo '%wheel ALL=(ALL:ALL) NOPASSWD: ALL' > /etc/sudoers.d/wheel; chmod 0440 /etc/sudoers.d/wheel"
    if ($LASTEXITCODE -ne 0) {
        Write-Error "FATAL: WSL user creation failed."
        exit 1
    }
    wsl --terminate archlinux
    Write-Host "WSL user '{{ .username }}' created. Distro restarted."
} else {
    Write-Host "WSL user '{{ .username }}' already exists."
}

wsl --set-default archlinux
Write-Host "Arch Linux is the default WSL distro."
Write-Host "INFO: Ending $PSCommandPath"
