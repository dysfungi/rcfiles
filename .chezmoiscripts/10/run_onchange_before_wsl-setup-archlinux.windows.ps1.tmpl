# Provision Arch Linux WSL distro: create user, install core packages, set as default.
# Idempotent — safe to re-run when script content changes (run_onchange).

$ErrorActionPreference = "Stop"
Write-Host "INFO: Starting $PSCommandPath"

# wsl --list outputs UTF-16LE; strip null bytes so -match works
wsl -d archlinux -- echo ok 2>$null
if ($LASTEXITCODE -ne 0) {
    Write-Host "Arch Linux WSL distro not available. Skipping."
    Write-Host "INFO: Ending $PSCommandPath"
    exit 0
}

Write-Host "Installing core packages in Arch Linux WSL..."
wsl -d archlinux -u root -- bash -c 'pacman -Syu --noconfirm --needed base-devel git chezmoi tmux'
if ($LASTEXITCODE -ne 0) {
    Write-Error "FATAL: pacman install failed in Arch Linux WSL."
    exit 1
}

wsl -d archlinux -u root -- id {{ .chezmoi.username }} 2>$null
if ($LASTEXITCODE -ne 0) {
    Write-Host "Creating WSL user '{{ .chezmoi.username }}'..."
    wsl -d archlinux -u root -- bash -c "set -e; useradd -m -G wheel {{ .chezmoi.username }}; passwd -l {{ .chezmoi.username }}; printf '[user]\ndefault={{ .chezmoi.username }}\n' > /etc/wsl.conf; echo '%wheel ALL=(ALL:ALL) NOPASSWD: ALL' > /etc/sudoers.d/wheel; chmod 0440 /etc/sudoers.d/wheel"
    if ($LASTEXITCODE -ne 0) {
        Write-Error "FATAL: WSL user creation failed."
        exit 1
    }
    wsl --terminate archlinux
    Write-Host "WSL user '{{ .chezmoi.username }}' created. Distro restarted."
} else {
    Write-Host "WSL user '{{ .chezmoi.username }}' already exists."
}

wsl --set-default archlinux
Write-Host "Arch Linux is the default WSL distro."
Write-Host "INFO: Ending $PSCommandPath"
