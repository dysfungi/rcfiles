#!/usr/bin/env bash
# Sync AUR packages via yay on Arch Linux.
# Reads aur: fields from .chezmoidata/packages.yaml.
# Idempotent — yay -S --needed skips already-installed packages.

set -euo pipefail

echo >&2 "INFO: Starting $0"

if ! command -v yay >/dev/null 2>&1; then
  echo >&2 "WARNING: yay not found; skipping AUR sync."
  echo >&2 "INFO: Ending $0"
  exit 0
fi

userName="$(whoami)"
hostName="$(hostname)"
bakSuffix="${userName}.${hostName}"
bakDir="${CHEZMOI_SOURCE_DIR}/.backups"
bakFile="${bakDir}/yay-packages.${bakSuffix}"

mkdir -p "${bakDir}"

_commit_backup() {
  local clarifier="${1:?required}"
  local action="${2:?required}"

  local -x GIT_DIR="${CHEZMOI_SOURCE_DIR}/.git"
  local -x GIT_WORK_TREE="${CHEZMOI_WORKING_TREE}"

  git add "${bakFile}"
  if ! git diff --cached --quiet -- "${bakDir}"; then
    git commit --no-verify --message "chore(backups): List yay/AUR packages ${clarifier} ${action} for ${userName} on ${hostName}" -- "${bakDir}"
  fi
}

backup() {
  local clarifier="${1:?required}"
  local action="${2:?required}"

  pacman -Qqm | sort >"${bakFile}"

  _commit_backup "${clarifier}" "${action}"
}
{{- $aurPkgs := list }}
{{- range $name, $pkg := .my.packages }}
  {{- if hasKey $pkg "aur" }}
    {{- $aurPkgs = append $aurPkgs $pkg.aur }}
  {{- end }}
{{- end }}
{{- if .is_riot_machine }}
  {{- range $name, $pkg := .riot.packages }}
    {{- if hasKey $pkg "aur" }}
      {{- $aurPkgs = append $aurPkgs $pkg.aur }}
    {{- end }}
  {{- end }}
{{- end }}

declared_packages="{{ join " " $aurPkgs }}"

if [ -z "$declared_packages" ]; then
  echo >&2 "INFO: No AUR packages declared; skipping."
  echo >&2 "INFO: Ending $0"
  exit 0
fi

backup before install

# cdargs 1.35 has fprintf(stderr, msg) that -Werror=format-security rejects on modern GCC;
# pass a custom makepkg.conf that appends -Wno-error to override it for all AUR builds here.
_makepkg_conf=$(mktemp /tmp/makepkg.XXXXXX.conf)
trap 'rm -f "$_makepkg_conf"' EXIT
{
  cat /etc/makepkg.conf
  echo 'CFLAGS+=" -Wno-error=format-security"'
  echo 'CXXFLAGS+=" -Wno-error=format-security"'
} >"$_makepkg_conf"

echo >&2 "INFO: Installing declared AUR packages via yay..."
# shellcheck disable=SC2086
yay -Syu --noconfirm --needed --mflags "--skippgpcheck --config $_makepkg_conf" $declared_packages

backup after install

echo >&2 "INFO: yay AUR sync complete."
echo >&2 "INFO: Ending $0"
