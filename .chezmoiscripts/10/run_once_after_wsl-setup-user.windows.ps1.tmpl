# Create the WSL Arch Linux user after chezmoi applies files.
# Skips if WSL is not installed or user already exists (idempotent).

$distros = wsl --list --quiet 2>$null
if ($LASTEXITCODE -ne 0 -or [string]::IsNullOrWhiteSpace($distros)) {
    Write-Output "No WSL distributions installed. Skipping."
    exit 0
}

wsl -d archlinux -u root -- id {{ .chezmoi.username }} 2>$null
if ($LASTEXITCODE -eq 0) {
    Write-Output "WSL user '{{ .chezmoi.username }}' already exists. Skipping."
    exit 0
}

$env:WSL_SETUP_PW = '{{ onepasswordRead "op://Riot/SSO/password" }}'
$env:WSLENV = ($env:WSLENV + ":WSL_SETUP_PW").TrimStart(":")

Write-Output "Creating WSL user '{{ .chezmoi.username }}'..."
wsl -d archlinux -u root -- bash -c '
    set -e
    pacman -Sy --noconfirm sudo
    useradd -m -G wheel {{ .chezmoi.username }}
    printf "{{ .chezmoi.username }}:%s\n" "$WSL_SETUP_PW" | chpasswd
    printf "[user]\ndefault={{ .chezmoi.username }}\n" > /etc/wsl.conf
    echo "%wheel ALL=(ALL:ALL) NOPASSWD: ALL" > /etc/sudoers.d/wheel
    chmod 0440 /etc/sudoers.d/wheel
'
Remove-Item Env:WSL_SETUP_PW -ErrorAction SilentlyContinue

wsl --terminate archlinux
Write-Output "Done. WezTerm will open into WSL Arch Linux on next launch."
