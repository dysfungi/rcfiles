#!/usr/bin/env bash
# Sync pacman packages in Arch Linux (WSL or otherwise).
# Reads pacman: fields from .chezmoidata/packages.yaml. AUR packages (aur: field) are handled by sync-yay.
# Idempotent — safe to re-run.

set -euo pipefail

echo >&2 "INFO: Starting $0"

if ! command -v pacman >/dev/null 2>&1; then
    echo >&2 "WARNING: pacman not found; skipping."
    echo >&2 "INFO: Ending $0"
    exit 0
fi

userName="$(whoami)"
hostName="$(hostname)"
bakSuffix="${userName}.${hostName}"
bakDir="${CHEZMOI_SOURCE_DIR}/.backups"
bakFile="${bakDir}/pacman-packages.${bakSuffix}"
export GIT_DIR="${CHEZMOI_SOURCE_DIR}/.git"
export GIT_WORK_TREE="${CHEZMOI_WORKING_TREE}"

mkdir -p "${bakDir}"

backup() {
  local clarifier="${1:?required}"
  local action="${2:?required}"

  sudo pacman -Qqe | sort >"${bakFile}"
  git add "${bakFile}"
  if ! git diff --cached --quiet -- "${bakDir}"; then
    git commit --message "chore(backups): List pacman packages ${clarifier} ${action} for ${userName} on ${hostName}" -- "${bakDir}"
  fi
}

{{ $packages := list }}
{{- range $name, $pkg := .my.packages }}
  {{- if hasKey $pkg "pacman" }}
    {{- $packages = append $packages (printf "%s" $pkg.pacman) }}
  {{- end }}
{{- end }}
{{- if .isRiotMachine }}
  {{- range $name, $pkg := .riot.packages }}
    {{- if hasKey $pkg "pacman" }}
      {{- $packages = append $packages (printf "%s" $pkg.pacman) }}
    {{- end }}
  {{- end }}
{{- end }}

declared_packages="{{ join " " $packages }}"

backup before install

if [ -n "$declared_packages" ]; then
    echo >&2 "INFO: Installing declared pacman packages..."
    # shellcheck disable=SC2086
    sudo pacman -Syu --noconfirm --needed $declared_packages
fi

backup after install

echo >&2 "INFO: Cleaning pacman cache..."
sudo pacman -Sc --noconfirm

echo >&2 "INFO: pacman sync complete."
echo >&2 "INFO: Ending $0"
