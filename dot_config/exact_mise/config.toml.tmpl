# https://mise.jdx.dev/configuration.html

min_version = "2024.9.5"


[settings]
# https://mise.jdx.dev/configuration/settings.html

experimental = true
idiomatic_version_file_enable_tools = ["python"]

trusted_config_paths = [
  # Chezmoi source dir — covers .mise.toml in repo root and any .worktrees/*/
  {{ joinPath .chezmoi.homeDir ".local/share/chezmoi" | quote }},
]

[tools]
# https://mise.jdx.dev/dev-tools/
# Generated from .chezmoidata/packages.yaml (mise entries)

{{ range $name, $pkg := .my.packages -}}
  {{ if not (hasKey $pkg "mise") }}{{ continue }}{{ end -}}
  {{ $skipList := list -}}
  {{ if hasKey $pkg "skip" }}{{ $skipList = $pkg.skip }}{{ end -}}
  {{ if and $.is_darwin (has "darwin" $skipList) }}{{ continue -}}
  {{ else if and $.is_linux (has "linux" $skipList) }}{{ continue -}}
  {{ else if and $.is_windows (has "windows" $skipList) }}{{ continue -}}
  {{ end -}}
{{ $version := "latest" -}}
  {{ if hasKey $pkg "version" }}{{ $version = $pkg.version }}{{ end -}}
{{ $pkg.mise | quote }} = {{ $version | quote }}
{{ end }}

[plugins]
# https://mise.jdx.dev/plugin-usage.html#configuration

[alias]
# https://mise.jdx.dev/dev-tools/aliases.html

[env]
# Optional local dotenv — skipped silently if absent (no .env required)
_.file = ".env"

# First-class, bootstrap-level creds.
{{- if not (env "OP_SERVICE_ACCOUNT_TOKEN") }}
OP_SERVICE_ACCOUNT_TOKEN = "{{ .op_service_account_token }}"
{{- else if .is_my_machine }}
OP_SERVICE_ACCOUNT_TOKEN = "{{ onepasswordRead "op://CLI/1Password Service Account - CLI - Personal/credential" }}"
{{- else if .is_work_machine }}
OP_SERVICE_ACCOUNT_TOKEN = "{{ onepasswordRead "op://CLI/1Password Service Account - CLI - Work/credential" }}"
{{- end }}
CHEZMOI_GITHUB_ACCESS_TOKEN = "{{ .github_token }}"

# Non-bootstrap
TODOIST_API_TOKEN = "{{"{{"}} exec(command=\"op read 'op://CLI/Todoist API Token - CLI/credential'\", cache_key='todoist_api_token') {{"}}"}}"
