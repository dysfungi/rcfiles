# Chezmoi-rendered secrets (0600). ALL secret env vars live here as
# render-time static values — no mise `exec()` templates — so the [env]
# table can never fail at mise-eval time. That all-static property is what
# lets cron wrap chezmoi in `mise x`.

[env]

# Secrets for all machines:
CHEZMOI_GITHUB_ACCESS_TOKEN = {{ .github_token | quote }}
OP_SERVICE_ACCOUNT_TOKEN = {{ .op_service_account_token | quote }}
TODOIST_API_TOKEN = {{ onepasswordRead "op://CLI/Todoist API Token - CLI/credential" | quote }}
{{- if .is_my_machine }}

# Secrets only for my machines:
GEMINI_API_KEY = {{ onepasswordRead "op://CLI/Gemini API Key - Frankish/credential" | quote }}
{{- else if .is_riot_machine }}

# Secrets only for Riot machines:
DATADOG_API_KEY = {{ onepasswordRead "op://Riot/Datadog Access Keys - CLI/API Key/api key" | quote }}
DATADOG_APP_KEY = {{ onepasswordRead "op://Riot/Datadog Access Keys - CLI/Application Key/app key" | quote }}
OPENAI_API_KEY = {{ onepasswordRead "op://Riot/TrueFoundry - Personal Access Token/credential" | quote }}
# OPENAI_BASE_URL stays with the key: the TrueFoundry proxy is Riot-only
# infra, and exporting the URL alone would point OpenAI SDK tooling at an
# unreachable host on personal machines (matches
# dot_codex/private_auth.json.tmpl).
OPENAI_BASE_URL = "https://truefoundry.riotgames.io/api/llm"

{{- end }}
