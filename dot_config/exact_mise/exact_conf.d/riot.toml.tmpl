{{- if and .is_riot_machine (not .is_windows) -}}

[plugins]
# https://mise.jdx.dev/plugin-usage.html#configuration

riot = "https://x-token:{{ .riot_github_token }}@gh.riotgames.com/gkisel/mise-plugin-riot.git"

[tools]
# Generated from .chezmoidata/packages.yaml (riot mise entries)
{{ range $name, $pkg := .riot.packages -}}
{{ if not (hasKey $pkg "mise") }}{{ continue }}{{ end -}}
{{ $skipList := list -}}
{{ if hasKey $pkg "skip" }}{{ $skipList = $pkg.skip }}{{ end -}}
{{ if and $.is_darwin (has "darwin" $skipList) }}{{ continue -}}
{{ else if and $.is_linux (has "linux" $skipList) }}{{ continue -}}
{{ else if and $.is_windows (has "windows" $skipList) }}{{ continue -}}
{{ end -}}
{{ $version := "latest" -}}
{{ if hasKey $pkg "version" }}{{ $version = $pkg.version }}{{ end -}}
{{ $pkg.mise | quote }} = {{ $version | quote }}
{{ end }}
# https://gh.riotgames.com/gkisel/mise-plugin-riot/tree/main?tab=readme-ov-file#linux-ssl-certificate-setup
# Riot's internal services (eg, keyconjurer) use a CA that is not in the default Linux trust store.
# Commented-out riot plugin packages are documented in .chezmoidata/packages.yaml

{{- end }}
