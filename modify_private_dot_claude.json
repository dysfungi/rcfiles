{{- /* chezmoi:modify-template */ -}}
{{- $config := fromJson (default "{}" (trim .chezmoi.stdin)) -}}

{{- $mcpServersOut := default (dict) (get $config "mcpServers") -}}
{{- $mcpServersIn := .my.mcpServers }}
{{- if .isRiotMachine -}}
  {{- $mcpServersIn = mergeOverwrite $mcpServersIn .riot.mcpServers -}}
{{- end -}}
{{- range $mcpName, $mcp := $mcpServersIn -}}
  {{- $mcpEntry := dict -}}
  {{- if hasKey $mcp "uvx" -}}
    {{- $uvx := index $mcp "uvx" -}}
    {{- $args := list (index $uvx "package") -}}
    {{- if hasKey $uvx "args" -}}
      {{- $args = concat $args (index $uvx "args") -}}
    {{- end -}}
    {{- $mcpEntry = dict "type" "stdio" "command" "uvx" "args" $args -}}
  {{- else -}}
    {{- $mcpEntry = dict "type" "http" "url" (index $mcp "serverUrl") -}}
    {{- if hasKey $mcp "auth" -}}
      {{- if eq (index $mcp.auth "type") "bearer" -}}
        {{- $token := onepasswordRead $mcp.auth.opPath -}}
        {{- $mcpEntry = set $mcpEntry "headers" (dict "Authorization" (printf "Bearer %s" $token)) -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
  {{- if hasKey $mcp "env" -}}
    {{- $renderedEnv := dict -}}
    {{- range $k, $v := index $mcp "env" -}}
      {{- $rendered := tpl $v $ -}}
      {{- if $rendered -}}
        {{- $renderedEnv = set $renderedEnv $k $rendered -}}
      {{- end -}}
    {{- end -}}
    {{- if $renderedEnv -}}
      {{- $mcpEntry = set $mcpEntry "env" $renderedEnv -}}
    {{- end -}}
  {{- end -}}
  {{- $mcpServersOut = set $mcpServersOut $mcpName $mcpEntry -}}
{{- end -}}
{{- $config = set $config "mcpServers" $mcpServersOut -}}

{{- $projectsOut := dig "projects" (dict) $config -}}
{{- $projectsIn := .my.projects }}
{{- if .isRiotMachine -}}
  {{- $projectsIn = concat $projectsIn .riot.projects -}}
{{- end -}}
{{- range $index, $project := $projectsIn -}}
  {{- $projectKey := (dig "isHomeRelative" false $project | ternary (joinPath $.chezmoi.homeDir $project.path) $project.path) -}}
  {{- $projectConfig := dig $projectKey (dict) $projectsOut | setValueAtPath "hasTrustDialogAccepted" true -}}
  {{- $projectsOut = set $projectsOut $projectKey $projectConfig -}}
{{- end -}}
{{- $config = set $config "projects" $projectsOut -}}

{{- mustToPrettyJson $config }}
