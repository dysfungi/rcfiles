#!/usr/bin/env -S uv run --script --no-project
# vim: ft=gotmpl.python
"""
Manages ~/.claude.json (Claude Code per-user config: MCP servers + project trust).

Merges managed MCP server entries and project trust keys into the existing file,
preserving any keys Claude adds at runtime (numStartups, tipsHistory, etc.).

Go template injects raw chezmoidata and resolves machine/platform conditionals
into Python constants; all transformation and merge logic is Python.

MCP env vars that require platform-conditional values (e.g. P4PORT differs by OS)
are resolved via named templates in .chezmoitemplates/env-files/ and injected as
MCP_ENV_OVERRIDES, keyed by server name.
"""
{{- $allMcpServers := mergeOverwrite .my.mcpServers (ternary .riot.mcpServers (dict) .isRiotMachine) -}}
{{- $mcpEnvOverrides := dict -}}
{{- range $name, $mcp := $allMcpServers -}}
  {{- if hasKey $mcp "env_tmpl" -}}
    {{- $mcpEnvOverrides = set $mcpEnvOverrides $name (includeTemplate (index $mcp "env_tmpl") $ | fromYaml) -}}
  {{- end -}}
{{- end }}
import json
import subprocess
import sys
from pathlib import Path

HOME_DIR = Path({{ .chezmoi.homeDir | quote }})
MCP_SERVERS: dict = json.loads({{ $allMcpServers | mustToJson | quote }})
MCP_ENV_OVERRIDES: dict = json.loads({{ $mcpEnvOverrides | mustToJson | quote }})
PROJECTS: list = json.loads({{ concat .my.projects (ternary .riot.projects (list) .isRiotMachine) | mustToJson | quote }})


def op_read(path: str) -> str:
    return subprocess.run(
        ["op", "read", path], capture_output=True, text=True, check=True
    ).stdout.strip()


def build_mcp_entry(name: str, mcp: dict) -> dict:
    if "uvx" in mcp:
        uvx = mcp["uvx"]
        entry: dict = {"type": "stdio", "command": "uvx", "args": [uvx["package"]] + uvx.get("args", [])}
    else:
        entry = {"type": "http", "url": mcp["serverUrl"]}
        auth = mcp.get("auth", {})
        if auth.get("type") == "bearer":
            entry["headers"] = {"Authorization": f"Bearer {op_read(auth['opPath'])}"}

    if "env" in mcp:
        entry["env"] = mcp["env"]
    elif name in MCP_ENV_OVERRIDES:
        entry["env"] = MCP_ENV_OVERRIDES[name]

    return entry


def resolve_project_key(project: dict) -> str:
    path = project["path"]
    return str(HOME_DIR / path) if project.get("isHomeRelative") else path


def main() -> None:
    stdin = sys.stdin.read().strip()
    config = json.loads(stdin) if stdin else {}

    mcp = config.setdefault("mcpServers", {})
    for name, server in MCP_SERVERS.items():
        mcp[name] = build_mcp_entry(name, server)

    projects = config.setdefault("projects", {})
    for project in PROJECTS:
        projects.setdefault(resolve_project_key(project), {})["hasTrustDialogAccepted"] = True

    print(json.dumps(config, indent=2))


if __name__ == "__main__":
    main()
