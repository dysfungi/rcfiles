#!/usr/bin/env -S uv run --script --no-project
# vim: ft=gotmpl.python
"""
Manages ~/.claude.json (Claude Code per-user config: MCP servers + project trust).

Merges managed MCP server entries and project trust keys into the existing file,
preserving any keys Claude adds at runtime (numStartups, tipsHistory, etc.).

MCP server and project data are rendered from .chezmoidata/{mcp-servers,projects}.yaml
at chezmoi apply time via Go template, producing Python constants below.
"""
import json
import sys
{{- /* Build managed MCP server map from chezmoidata */ -}}
{{- $mcpServersIn := .my.mcpServers -}}
{{- if .isRiotMachine -}}
  {{- $mcpServersIn = mergeOverwrite $mcpServersIn .riot.mcpServers -}}
{{- end -}}
{{- $managedMcp := dict -}}
{{- range $name, $mcp := $mcpServersIn -}}
  {{- $entry := dict -}}
  {{- if hasKey $mcp "uvx" -}}
    {{- $uvx := index $mcp "uvx" -}}
    {{- $args := list (index $uvx "package") -}}
    {{- if hasKey $uvx "args" -}}{{- $args = concat $args (index $uvx "args") -}}{{- end -}}
    {{- $entry = dict "type" "stdio" "command" "uvx" "args" $args -}}
  {{- else -}}
    {{- $entry = dict "type" "http" "url" (index $mcp "serverUrl") -}}
    {{- if hasKey $mcp "auth" -}}
      {{- if eq (index $mcp.auth "type") "bearer" -}}
        {{- $token := onepasswordRead $mcp.auth.opPath -}}
        {{- $entry = set $entry "headers" (dict "Authorization" (printf "Bearer %s" $token)) -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
  {{- if hasKey $mcp "env" -}}
    {{- $entry = set $entry "env" (index $mcp "env") -}}
  {{- else if hasKey $mcp "envProfile" -}}
    {{- if eq (index $mcp "envProfile") "p4" -}}
      {{- $p4env := dict "P4CHARSET" "utf8" "P4USER" $.username -}}
      {{- if $.isDarwin -}}
        {{- $p4env = set $p4env "P4PORT" "PERFLAX01:1666" -}}
      {{- else -}}
        {{- $p4env = set $p4env "P4PORT" "ssl:uegames.p4.riotgames.io:1666" -}}
        {{- $p4env = set $p4env "P4CONFIG" ".p4config" -}}
      {{- end -}}
      {{- $entry = set $entry "env" $p4env -}}
    {{- end -}}
  {{- end -}}
  {{- $managedMcp = set $managedMcp $name $entry -}}
{{- end -}}
{{- $projectsIn := .my.projects -}}
{{- if .isRiotMachine -}}
  {{- $projectsIn = concat $projectsIn .riot.projects -}}
{{- end -}}
{{- $projectKeys := list -}}
{{- range $_, $project := $projectsIn -}}
  {{- $key := (dig "isHomeRelative" false $project | ternary (joinPath $.chezmoi.homeDir $project.path) $project.path) -}}
  {{- $projectKeys = append $projectKeys $key -}}
{{- end }}

MANAGED_MCP_SERVERS = {{ $managedMcp | mustToJson }}
MANAGED_PROJECT_KEYS = {{ $projectKeys | mustToJson }}


def main() -> None:
    stdin = sys.stdin.read().strip()
    config = json.loads(stdin) if stdin else {}

    config.setdefault("mcpServers", {}).update(MANAGED_MCP_SERVERS)

    projects = config.setdefault("projects", {})
    for key in MANAGED_PROJECT_KEYS:
        projects.setdefault(key, {})["hasTrustDialogAccepted"] = True

    print(json.dumps(config, indent=2))


if __name__ == "__main__":
    main()
