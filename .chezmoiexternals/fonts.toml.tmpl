{{ $fontsDir := ternary "Library/Fonts" (ternary "AppData/Local/Microsoft/Windows/Fonts" "TODO(linux)" .is_windows) .is_mac }}
{{- /* Windows memory-maps loaded fonts; they can't be overwritten while in use.
       Disable refresh so chezmoi only extracts once (during init, before fonts load).
       Font updates on Windows require a logout/re-login regardless. */}}
{{ $refreshPeriod := ternary "0" "168h" .is_windows }}

[fonts-iosevka]
targetPath = {{ joinPath $fontsDir "Iosevka" | quote }}
type = "archive"
url = {{ gitHubLatestReleaseAssetURL "be5invis/Iosevka" "PkgTTC-Iosevka-*.zip" | quote }}
refreshPeriod = {{ $refreshPeriod | quote }}

[fonts-powerlevel10k]
targetPath = {{ joinPath $fontsDir "PowerLevel10k" | quote }}
type = "archive"
url = "https://github.com/romkatv/powerlevel10k-media/archive/master.tar.gz"
exact = false
stripComponents = 1
refreshPeriod = {{ $refreshPeriod | quote }}
include = ["*/*.ttf"]

[fonts-source_code_pro]
targetPath = {{ joinPath $fontsDir "SourceCodePro" | quote }}
type = "archive"
url = "https://github.com/adobe-fonts/source-code-pro/archive/master.tar.gz"
exact = false
stripComponents = 2
refreshPeriod = {{ $refreshPeriod | quote }}
include = ["**/*.ttf"]
