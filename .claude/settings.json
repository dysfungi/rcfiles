{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-check.sh\" session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-check.sh\" pre-tool-use",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/migrate-permissions.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bash *)",
      "Bash(xonsh *)",
      "Bash(zsh *)",

      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(col *)",
      "Bash(cut *)",
      "Bash(diff *)",
      "Bash(dir *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(iconv *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(tr *)",
      "Bash(tree *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(xargs *)",
      "Bash(xxd *)",

      "Bash(chmod +x *)",
      "Bash(command -v *)",
      "Bash(date *)",
      "Bash(defaults read *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(getent passwd *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(printenv *)",
      "Bash(unset *)",
      "Bash(which *)",

      "Bash(git *)",
      "Bash(p4 *)",

      "Bash(brew *)",
      "Bash(pacman *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(yay *)",

      "Bash(check-jsonschema *)",
      "Bash(chezmoi *)",
      "Bash(curl *)",
      "Bash(go *)",
      "Bash(luac *)",
      "Bash(mise *)",
      "Bash(nvim *)",
      "Bash(op read *)",
      "Bash(pre-commit *)",
      "Bash(python3 *)",
      "Bash(shellcheck *)",
      "Bash(tic *)",
      "Bash(tmux *)",
      "Bash(todo *)",
      "Bash(todo.sh *)",
      "Bash(tree-sitter *)",
      "Bash(yamllint *)",

      "Bash(wsl *)",
      "Bash(wsl.exe *)",

      "PowerShell($env:COMPUTERNAME)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Select-Object *)",
      "PowerShell(Sort-Object *)",

      "Read(//Users/dfrank/**)",
      "Read(//Users/dmf/**)",
      "Read(//home/dfrank/**)",
      "Read(//mnt/t/p4/flyingfox/dev-main/**)",
      "Read(//mnt/t/p4/lion/dev-main/**)",
      "Read(//opt/homebrew/**)",

      "WebFetch(domain:archlinux.org)",
      "WebFetch(domain:aur.archlinux.org)",
      "WebFetch(domain:chezmoi.io)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:masterminds.github.io)",
      "WebFetch(domain:mise.jdx.dev)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:support.1password.com)",
      "WebFetch(domain:www.chezmoi.io)",
      "WebFetch(domain:xon.sh)",
      "WebSearch"
    ],
    "deny": [
      "Bash(git branch -D *)",
      "Bash(git clean -f *)",
      "Bash(git filter-branch *)",
      "Bash(git push --delete *)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git stash clear)",
      "Bash(git stash drop)",
      "Bash(git stash drop *)",
      "Bash(p4 obliterate *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  }
}
