{
  {{- /*
    pi keybindings — https://pi.dev/docs/latest/keybindings (docs/keybindings.md)

    Preference: Enter inserts a newline; submit with Ctrl+Enter.

    Trying Ctrl+Enter as the primary submit key. The earlier concern — that most
    terminals send an identical carriage-return byte for Enter, Shift+Enter, and
    Ctrl+Enter unless they speak the kitty keyboard protocol — was never actually
    verified in this terminal, so we're testing whether Ctrl+Enter works here.
    Ctrl+J is kept as a fallback because it emits a distinct line-feed byte and
    therefore works as a submit key in every terminal.

    Rendered as a chezmoi template purely so this rationale survives as a comment;
    the emitted file is plain JSON (pi rejects non-keybinding keys like "_comment").
  */ -}}
  "tui.input.newLine": ["enter", "shift+enter"],
  "tui.input.submit": ["ctrl+enter", "ctrl+j"]
}
