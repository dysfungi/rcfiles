  "defaultProvider": "truefoundry",
  {{- else }}
  "defaultModel": "claude-opus-4-8",
  "defaultProvider": "anthropic",
  {{- end }}
  "defaultProjectTrust": "always",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "lastChangelogVersion": "0.79.9",
  "theme": "dark"
}
