{ {{- /* https://pi.dev/docs/latest/settings */}}
  {{- if .isRiotMachine }}
  {{- /* Riot machines have no direct Anthropic access; route via the TrueFoundry
         gateway provider defined in private_models.json.tmpl. */}}
  "defaultModel": "claude-vertex/anthropic-claude-opus-4-8",
  "defaultProvider": "truefoundry",
  {{- else }}
  "defaultModel": "claude-opus-4-8",
  "defaultProvider": "anthropic",
  {{- end }}
  {{- /* enabledModels: Ctrl+P cycling rotation — latest of each tier, base context only.
       Use /model to reach older versions or [1m] variants when needed. */}}
  "enabledModels": [
    {{- if .isRiotMachine }}
    "claude-vertex/anthropic-claude-opus-4-8",
    "claude-vertex/anthropic-claude-sonnet-4-6-default"
    {{- else }}
    "claude-opus-4-8",
    "claude-sonnet-4-6"
    {{- end }}
  ],
  "packages": [
    "npm:@rezamonangg/pi-worktree",
    "npm:pi-mcp-adapter"
  ],
  "defaultProjectTrust": "always",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "lastChangelogVersion": "0.79.9",
  "theme": "dark"
}
