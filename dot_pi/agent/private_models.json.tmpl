{
  {{- /*
    pi custom providers — https://pi.dev/docs/latest/providers (models.json reference: docs/models.md)

    On Riot machines, pi has no direct Anthropic/OpenAI access; all traffic must route
    through the TrueFoundry LLM gateway (same proxy Codex and Claude Code use):
      - base:  https://truefoundry.riotgames.io/api/llm
      - auth:  Personal Access Token (PAT) from 1Password
      - wire:  anthropic-messages (parity with Claude Code's ANTHROPIC_BASE_URL path)

    The PAT is injected at `chezmoi apply` time via onepasswordRead and lands in a 0600
    file (private_ prefix). We deliberately avoid pi's `!command` apiKey form (`!op read ...`):
    pi applies no TTL/caching to command-based keys (docs/models.md), so it would shell out
    to 1Password on every request.

    Thinking format is PER-MODEL on this Vertex-behind-TrueFoundry backend (empirically probed
    against /v1/messages, 2026-06):
      - opus-4-7, opus-4-8 : require adaptive thinking (thinking.type 'adaptive' +
                             output_config.effort); they REJECT legacy with
                             400 "thinking.type.enabled is not supported ... Use adaptive".
      - opus-4-6, sonnet-4-6: accept BOTH.
    pi's default path is legacy budget thinking; compat.forceAdaptiveThinking switches a model
    to adaptive. We set it per-model ONLY where legacy is rejected (opus 4.7+), leaving every
    model that works on the default path untouched. The adaptive flag in $bases drives this.

    Model IDs come from the gateway's own /v1/models catalog (the 5 claude-vertex ids) and the
    live Claude Code config (dot_claude/settings.json.tmpl ANTHROPIC_DEFAULT_*_MODEL).

    1M context: models with oneM=true also get a [1m]-suffixed 1-million-token variant. The variant list below is generated from
    $bases so adding a new model/version stays a one-line change. Format is per Riot's
    TrueFoundry onboarding doc, e.g. claude-vertex/anthropic-claude-sonnet-4-6-default[1m].
    These [1m] ids are gated behind a separate 1M-tier access grant: as of setup this PAT
    403s on every [1m] id ("not authorized ... or model does not exist") while the base ids
    return 200. They are kept here so they work the moment access is granted (request via
    @prod-ai in #tm-centraltech-all). Cost is the base (≤200K) tier because pi uses a flat
    per-million rate and cannot model Anthropic's >200K premium tier.
  */ -}}
  {{- $opusCost := dict "input" 15 "output" 75 "cacheRead" 1.5 "cacheWrite" 18.75 -}}
  {{- $sonnetCost := dict "input" 3 "output" 15 "cacheRead" 0.3 "cacheWrite" 3.75 -}}
  {{- $bases := list
      (dict "id" "claude-vertex/anthropic-claude-opus-4-6"           "name" "Claude Opus 4.6"   "maxTokens" 32000 "oneM" true  "adaptive" false "cost" $opusCost)
      (dict "id" "claude-vertex/anthropic-claude-opus-4-7"           "name" "Claude Opus 4.7"   "maxTokens" 32000 "oneM" true  "adaptive" true  "cost" $opusCost)
      (dict "id" "claude-vertex/anthropic-claude-opus-4-8"           "name" "Claude Opus 4.8"   "maxTokens" 32000 "oneM" true  "adaptive" true  "cost" $opusCost)
      (dict "id" "claude-vertex/anthropic-claude-sonnet-4-6-default" "name" "Claude Sonnet 4.6" "maxTokens" 64000 "oneM" true  "adaptive" false "cost" $sonnetCost)

  -}}
  {{- $models := list -}}
  {{- range $b := $bases -}}
    {{- $models = append $models (dict "id" $b.id "name" (printf "%s (TrueFoundry)" $b.name) "ctx" 200000 "maxTokens" $b.maxTokens "adaptive" $b.adaptive "cost" $b.cost) -}}
    {{- if $b.oneM -}}
      {{- $models = append $models (dict "id" (printf "%s[1m]" $b.id) "name" (printf "%s 1M (TrueFoundry)" $b.name) "ctx" 1000000 "maxTokens" $b.maxTokens "adaptive" $b.adaptive "cost" $b.cost) -}}
    {{- end -}}
  {{- end -}}
  "providers": {
    {{- if .is_riot_machine }}
    "truefoundry": {
      "name": "TrueFoundry (Riot)",
      "baseUrl": "https://truefoundry.riotgames.io/api/llm",
      "api": "anthropic-messages",
      "apiKey": {{ onepasswordRead "op://Riot/TrueFoundry - Personal Access Token/credential" | quote }},
      "models": [
      {{- range $i, $m := $models }}
        {
          "id": {{ $m.id | quote }},
          "name": {{ $m.name | quote }},
          "reasoning": true,
          "input": ["text", "image"],
          "contextWindow": {{ $m.ctx }},
          "maxTokens": {{ $m.maxTokens }},
          "cost": { "input": {{ $m.cost.input }}, "output": {{ $m.cost.output }}, "cacheRead": {{ $m.cost.cacheRead }}, "cacheWrite": {{ $m.cost.cacheWrite }} }{{ if $m.adaptive }},
          {{- /* Vertex rejects legacy thinking for this model; force adaptive (thinking.type adaptive + output_config.effort). */}}
          "compat": { "forceAdaptiveThinking": true }{{ end }}
        }{{ if lt (add1 $i) (len $models) }},{{ end }}
      {{- end }}
      ]
    }
    {{- end }}
  }
}
