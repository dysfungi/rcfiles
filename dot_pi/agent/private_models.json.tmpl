{
  {{- /*
    pi custom providers — https://pi.dev/docs/latest/providers (models.json reference: docs/models.md)

    GENERATED from the central catalog .chezmoidata/large-language-models.yaml
    (namespace .riot.llm on Riot, else .my.llm). Add/toggle a model there, not here.

    One custom-provider block is emitted per distinct `gateway` referenced by an
    ENABLED model in the active namespace; built-in models (no gateway, e.g. the
    personal Anthropic models) are omitted here and resolved by pi's built-ins.

    API keys are read via onepasswordRead ONLY for gateways actually used by
    enabled models in the active namespace, so a personal machine never touches
    the Riot vault. The key lands in this 0600 file (private_ prefix); we avoid
    pi's `!command` apiKey form because pi caches no TTL for it (docs/models.md)
    and would shell out to 1Password on every request.

    Thinking format is PER-MODEL on the Vertex-behind-TrueFoundry backend
    (empirically probed against /v1/messages, 2026-06): opus 4.7+ REJECT legacy
    budget thinking with 400 "... Use adaptive", so those carry adaptive: true in
    the catalog, which emits compat.forceAdaptiveThinking here. Models that accept
    the default legacy path are left untouched.

    1M context: catalog models with one_m: true also get a [1m]-suffixed
    1-million-token variant (Riot TrueFoundry onboarding format). These [1m] ids
    are gated behind a separate 1M-tier access grant (PAT 403s until granted;
    request via @prod-ai in #tm-centraltech-all). Cost is the base (<=200K) tier
    because pi uses a flat per-million rate.
  */ -}}
  {{- $ns := .is_riot_machine | ternary .riot.llm .my.llm -}}
  {{ includeTemplate "llm/validate.tmpl" $ns -}}
  {{- /* Distinct custom-provider gateways used by enabled models, first-seen order. */ -}}
  {{- $providers := list -}}
  {{- $seen := dict -}}
  {{- range $m := $ns.models -}}
    {{- if and $m.enabled (hasKey $m "gateway") -}}
      {{- if not (hasKey $seen $m.gateway.provider) -}}
        {{- $_ := set $seen $m.gateway.provider true -}}
        {{- $providers = append $providers $m.gateway -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
  "providers": {
  {{- range $pi, $g := $providers }}
    {{ $g.provider | quote }}: {
      "name": {{ $g.name | quote }},
      "baseUrl": {{ $g.base_url | quote }},
      "api": {{ $g.api | quote }},
      "apiKey": {{ onepasswordRead $g.api_key_op | quote }},
      "models": [
      {{- /* Render list for this provider: each enabled model, plus its [1m] variant. */ -}}
      {{- $rendered := list -}}
      {{- range $m := $ns.models -}}
        {{- if and $m.enabled (hasKey $m "gateway") (eq $m.gateway.provider $g.provider) -}}
          {{- $rendered = append $rendered (dict "m" $m "id" $m.id "ctx" $m.ctx "oneMVariant" false) -}}
          {{- if dig "one_m" false $m -}}
            {{- $rendered = append $rendered (dict "m" $m "id" (printf "%s[1m]" $m.id) "ctx" 1000000 "oneMVariant" true) -}}
          {{- end -}}
        {{- end -}}
      {{- end }}
      {{- range $ri, $r := $rendered }}
        {{- $m := $r.m }}
        {
          "id": {{ $r.id | quote }},
          "name": {{ printf "%s%s" (default $m.id (dig "display_name" "" $m)) (ternary " 1M" "" $r.oneMVariant) | quote }},
          "reasoning": {{ dig "reasoning" false $m }},{{ if dig "reasoning" false $m }}
          "thinkingLevelMap": {{ $m.thinking_level_map | mustToJson }},{{ end }}
          "input": ["text", "image"],
          "contextWindow": {{ $r.ctx }},
          "maxTokens": {{ $m.max_tokens }},
          "cost": { "input": {{ $m.cost.input }}, "output": {{ $m.cost.output }}, "cacheRead": {{ dig "cost" "cache_read" 0 $m }}, "cacheWrite": {{ dig "cost" "cache_write" 0 $m }} }{{ if dig "adaptive" false $m }},
          {{- /* Vertex rejects legacy thinking for this model; force adaptive (thinking.type adaptive + output_config.effort). */}}
          "compat": { "forceAdaptiveThinking": true }{{ end }}
        }{{ if lt (add1 $ri) (len $rendered) }},{{ end }}
      {{- end }}
      ]
    }{{ if lt (add1 $pi) (len $providers) }},{{ end }}
  {{- end }}
  }
}
