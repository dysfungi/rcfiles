##########################################
# https://www.chezmoi.io/reference/special-files/chezmoiignore/
#
# Chezmoi ignores hidden/dot files!
# https://www.chezmoi.io/user-guide/frequently-asked-questions/design/#why-does-chezmoi-use-weird-filenames
#
# This ignore file is heavily inspired by:
#   https://github.com/KevinNitroG/dotfiles/blob/cdefce4e682690b5412c00ba2e06022a7a96218b/home/.chezmoiignore.tmpl
##########################################

# General
**/LICENSE
**/README*
todo.txt
done.txt
report.txt

# Agents
AGENTS*
CLAUDE*
GEMINI*

# Logs
**/*.log

# SSH: per-host keypair is generated on the machine (see
# .chezmoiscripts/20/run_before_generate-ssh-key.unix-like.sh). It has no
# declarative source, so it is intentionally NOT chezmoi-managed on any platform.
.ssh/id_ed25519
.ssh/id_ed25519.pub

# Neovim
**/.luarc.json
**/spell/
**/tags
**/test.sh

# Node
**/node_modules/

# Python
**/__pycache__/
**/*.pyc
**/*.pyi
pyproject.toml
uv.lock

##########################################

{{ if .is_windows }}

# Native Windows Parsec reads its config from AppData\Roaming\Parsec instead.
.parsec/**

.local/bin/*.sh

.config/Code/
.config/bat/
.config/crontab/
.config/crontab/**
.config/fd/
.config/gdu/
.config/kanata/
.config/karabiner/
.config/kitty
.config/kitty/**
.config/lazygit/
.config/rclone/
.config/rclone/**
.config/vlc/

.font/
.npm-global/

.profile
.tmux.conf
.zprofile
.zsh*

{{ else }}

.config/autohotkey/
.config/autohotkey/**
.config/komorebi/
.config/microsoft-office/
.config/scoop/
.config/scoop/**
.config/whkdrc/
.config/windows-tasks-scheduler/
.config/xinmeng/
.config/yasb/
AppData/
AppData/**
Documents/
Documents/**

.vsvimrc
.wslconfig

{{ end }}

{{ if .is_wsl }}
# WSL never runs a Parsec host, so this Unix-style config does not belong there.
.parsec/**
{{ end }}

##########################################

{{ if not .is_darwin }}

.chezmoiscripts/*.darwin.*
.chezmoiscripts/**/*.darwin.*

# antigravity-cli (Antigravity CLI) is a Homebrew cask (darwin-only), so agy
# never runs elsewhere; skip its native config off-darwin to avoid creating
# stray files: the modify_ settings.json and the MCP server config.
.gemini/antigravity-cli/settings.json
.gemini/config/mcp_config.json

{{ end }}

# The filtered Flyingfox sync policy currently targets the macOS Riot client.
{{ if not (and .is_darwin .is_riot_machine) }}
.local/bin/p4-sync-excluding-assets
.config/p4-sync/
.config/p4-sync/**
{{ end }}

{{ if not .is_linux }}

.chezmoiscripts/*.linux.*
.chezmoiscripts/**/*.linux.*
.chezmoiscripts/linux/**

.gtkrc-2.0.mine

.config/.ktrashrc
.config/.trashrc
.config/brave-flags.conf
.config/chrome-flags.conf
.config/chromium-flags.conf
.config/code-flags.conf
.config/dolphinrc
.config/electron-flags.conf
.config/kdeglobals
.config/libinput-gestures.conf
.config/mimeapps.list
.config/spotify-flags.conf

.config/fcitx5/
.config/fcitx5/**
.config/gammastep/
.config/hypr/
.config/hypr/**
.config/sddm/
.config/systemd/
.config/systemd/**
.config/tlp/

{{ end }}

{{ if not .is_unix_like }}

.chezmoiscripts/*.unix-like.*
.chezmoiscripts/**/*.unix-like.*

{{ end }}

{{ if not .is_windows }}

.chezmoiscripts/*.windows.*
.chezmoiscripts/**/*.windows.*

**.bat
**.ps1
**.reg

{{ end }}

##########################################
# Skills: machine-gated deployment
# my-perforce is Riot-only; my-therapy is personal-only.
# Filtering here (not in SKILL.md) keeps skill content clean and portable.

{{- if not .is_riot_machine }}
.claude/skills/my-perforce
.gemini/extensions/my-perforce
.codex/skills/my-perforce
.pi/agent/skills/my-perforce
{{- end }}

{{- if .is_work_machine }}
.claude/skills/my-therapy
.gemini/extensions/my-therapy
.codex/skills/my-therapy
.pi/agent/skills/my-therapy
{{- end }}
