# Force LF for all text files by default
* text=auto eol=lf

# Shell scripts must be LF
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# PowerShell can be CRLF (Windows-native)
*.ps1 text eol=crlf

# Templates follow their base extension
*.sh.tmpl text eol=lf
*.ps1.tmpl text eol=crlf

# Batch files are Windows-native
*.bat text eol=crlf
*.cmd text eol=crlf
*.reg text eol=crlf

# Append-only log files: keep all lines from both sides during merge.
# Without this, concurrent worktree sessions always conflict on the last
# line because git's default text merge can't tell that both sides only
# appended — it sees a modification, not a pure addition.
done.txt merge=union
todo.txt merge=union
