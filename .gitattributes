# Force LF for all text files by default
* text=auto eol=lf

# Shell scripts must be LF
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# PowerShell can be CRLF (Windows-native)
*.ps1 text eol=crlf

# Templates follow their base extension
*.sh.tmpl text eol=lf
*.ps1.tmpl text eol=crlf

# Batch files are Windows-native
*.bat text eol=crlf
*.cmd text eol=crlf
*.reg text eol=crlf
