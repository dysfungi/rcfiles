#!/usr/bin/env python3
import json
import sys

# Data baked in by chezmoi template rendering
managed_mcp = {{ mergeOverwrite .my.mcpServers (ternary .riot.mcpServers (dict) .isRiotMachine) | toJson }}
managed_projects = {{ (ternary (concat .my.projects .riot.projects) .my.projects .isRiotMachine) | toJson }}
home = {{ .chezmoi.homeDir | toJson }}

# Read current config from stdin (may be empty on first run)
try:
    config = json.load(sys.stdin)
except (json.JSONDecodeError, ValueError):
    config = {}

# Merge mcpServers: keep existing, assert/update managed entries
mcp_out = config.get("mcpServers", {})
for name, mcp in managed_mcp.items():
    mcp_out[name] = {"type": "http", "url": mcp["serverUrl"]}
config["mcpServers"] = mcp_out

# Merge projects: keep existing, ensure managed entries exist
projects_out = config.get("projects", {})
for project in managed_projects:
    key = (home + "/" + project["path"]) if project.get("isHomeRelative") else project["path"]
    projects_out.setdefault(key, {})
config["projects"] = projects_out

# Write result preserving key ordering (not sorted)
json.dump(config, sys.stdout, indent=2, sort_keys=False)
sys.stdout.write("\n")
