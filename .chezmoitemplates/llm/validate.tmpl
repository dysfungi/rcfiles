{{- /*
  Fail-loud guard for the LLM catalog. Include from each harness template:
    {{ includeTemplate "llm/validate.tmpl" $ns }}
  where $ns is the active `.my.llm` or `.riot.llm` object. Enforces invariants
  that JSON Schema cannot express (cross-entry uniqueness + vendor/wire compat).
  Emits nothing on success; aborts `chezmoi apply` with a message on violation.
*/ -}}
{{- $ns := . -}}
{{- /* Skip when not called with a namespace (e.g. the template linter renders
       this partial standalone against root data, which has no `models` key). */ -}}
{{- if and (kindIs "map" $ns) (hasKey $ns "models") -}}
{{- /* Each harness may be the default in at most one entry. */ -}}
{{- range $h := (list "pi" "codex" "claude" "agy") -}}
  {{- $seen := dict "n" 0 -}}
  {{- range $m := $ns.models -}}
    {{- if and (hasKey $m "default_for") (has $h $m.default_for) -}}
      {{- $_ := set $seen "n" (add $seen.n 1) -}}
    {{- end -}}
  {{- end -}}
  {{- if gt $seen.n 1 -}}
    {{- fail (printf "large-language-models.yaml: %d models claim default_for %q (expected at most 1)" $seen.n $h) -}}
  {{- end -}}
{{- end -}}
{{- /* Each CLI alias (opus/sonnet/haiku/...) may map to at most one model,
       else claude's alias derivation silently picks last-wins. */ -}}
{{- $aliasCount := dict -}}
{{- range $m := $ns.models -}}
  {{- if hasKey $m "alias" -}}
    {{- $_ := set $aliasCount $m.alias (add (dig $m.alias 0 $aliasCount) 1) -}}
  {{- end -}}
{{- end -}}
{{- range $a, $n := $aliasCount -}}
  {{- if gt $n 1 -}}
    {{- fail (printf "large-language-models.yaml: %d models share alias %q (expected at most 1)" $n $a) -}}
  {{- end -}}
{{- end -}}
{{- /* Reasoning models must declare every Pi logical thinking level. Explicit
       nulls hide unsupported levels; omitting a key would silently advertise it.
       Non-reasoning models must not carry a misleading map. JSON Schema closes
       the keys and validates value types; this guard enforces the conditional
       reasoning contract when templates render independently of the schema hook. */ -}}
{{- range $m := $ns.models -}}
  {{- $has_map := hasKey $m "thinking_level_map" -}}
  {{- if dig "reasoning" false $m -}}
    {{- if not $has_map -}}
      {{- fail (printf "large-language-models.yaml: reasoning model %s needs thinking_level_map" $m.id) -}}
    {{- end -}}
    {{- range $level := (list "off" "minimal" "low" "medium" "high" "xhigh" "max") -}}
      {{- if not (hasKey $m.thinking_level_map $level) -}}
        {{- fail (printf "large-language-models.yaml: reasoning model %s thinking_level_map is missing %q" $m.id $level) -}}
      {{- end -}}
    {{- end -}}
  {{- else if $has_map -}}
    {{- fail (printf "large-language-models.yaml: non-reasoning model %s must not declare thinking_level_map" $m.id) -}}
  {{- end -}}
{{- end -}}
{{- /* Each pi subagent role must select exactly one enabled model. The rendered
       agent frontmatter passes this id to `pi --model`, so dormant or missing
       mappings fail at apply time rather than failing a delegated task. */ -}}
{{- range $role := (list "scout" "planner" "reviewer" "worker") -}}
  {{- $seen := dict "n" 0 -}}
  {{- range $m := $ns.models -}}
    {{- if and (hasKey $m "subagent_roles") (has $role $m.subagent_roles) -}}
      {{- if not $m.enabled -}}
        {{- fail (printf "large-language-models.yaml: %s has subagent_roles %q but is disabled" $m.id $role) -}}
      {{- end -}}
      {{- $_ := set $seen "n" (add $seen.n 1) -}}
    {{- end -}}
  {{- end -}}
  {{- if ne $seen.n 1 -}}
    {{- fail (printf "large-language-models.yaml: %d models claim subagent_roles %q (expected exactly 1)" $seen.n $role) -}}
  {{- end -}}
{{- end -}}
{{- /* A default must be runnable by the harness it defaults for. */ -}}
{{- range $m := $ns.models -}}
  {{- if hasKey $m "default_for" -}}
    {{- if and (has "claude" $m.default_for) (ne $m.vendor "anthropic") -}}
      {{- fail (printf "large-language-models.yaml: %s is default_for claude but vendor is %q (claude runs only anthropic)" $m.id $m.vendor) -}}
    {{- end -}}
    {{- if and (has "agy" $m.default_for) (ne $m.vendor "google") -}}
      {{- fail (printf "large-language-models.yaml: %s is default_for agy but vendor is %q (agy runs only google)" $m.id $m.vendor) -}}
    {{- end -}}
    {{- if has "codex" $m.default_for -}}
      {{- /* Nested (not `or`) so we never read .gateway.api when gateway is absent.
             codex speaks the OpenAI wire (completions or responses). */ -}}
      {{- if not (hasKey $m "gateway") -}}
        {{- fail (printf "large-language-models.yaml: %s is default_for codex but has no gateway (needs an openai-* wire)" $m.id) -}}
      {{- else if not (hasPrefix "openai-" $m.gateway.api) -}}
        {{- fail (printf "large-language-models.yaml: %s is default_for codex but gateway api is %q (needs openai-completions or openai-responses)" $m.id $m.gateway.api) -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- end -}}
